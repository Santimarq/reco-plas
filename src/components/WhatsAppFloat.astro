---
// Floating WhatsApp button - aparece en todas las páginas
---

<div id="wa-float" class="wa-float">
  <a
    href="https://wa.me/543482312021?text=Hola!%20Quiero%20consultar%20por%20productos%20RecoPlas"
    target="_blank"
    rel="noopener"
    class="wa-float__btn"
    aria-label="Contactanos por WhatsApp"
  >
    <svg class="wa-float__icon" width="28" height="28" fill="#fff" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
  <div class="wa-float__tooltip">
    <span>Necesitas ayuda?</span>
    <button class="wa-float__tooltip-close" aria-label="Cerrar" id="wa-tooltip-close">&times;</button>
  </div>
</div>

<style>
  .wa-float {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 890;
    display: flex;
    align-items: center;
    gap: .65rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity .4s ease, transform .4s ease;
    pointer-events: none;
  }
  .wa-float.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .wa-float__btn {
    width: 60px; height: 60px;
    border-radius: 50%;
    background: #25D366;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 6px 24px rgba(37,211,102,.45), 0 2px 8px rgba(0,0,0,.1);
    transition: all .3s ease;
    position: relative;
  }
  .wa-float__btn:hover {
    background: #1ebe5b;
    transform: scale(1.08);
    box-shadow: 0 10px 32px rgba(37,211,102,.55), 0 4px 12px rgba(0,0,0,.15);
  }
  .wa-float__btn::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(37,211,102,.25);
    animation: wa-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes wa-ping {
    0% { transform: scale(1); opacity: .6; }
    75%, 100% { transform: scale(1.4); opacity: 0; }
  }

  .wa-float__icon {
    position: relative;
    z-index: 1;
  }

  /* Tooltip */
  .wa-float__tooltip {
    position: absolute;
    right: 72px;
    bottom: 10px;
    background: #fff;
    border-radius: 12px;
    padding: .6rem 1rem;
    box-shadow: 0 4px 20px rgba(0,0,0,.12);
    display: flex;
    align-items: center;
    gap: .5rem;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(8px);
    transition: opacity .3s ease, transform .3s ease;
    pointer-events: none;
  }
  .wa-float__tooltip.is-visible {
    opacity: 1;
    transform: translateX(0);
    pointer-events: all;
  }
  .wa-float__tooltip::after {
    content: '';
    position: absolute;
    right: -6px;
    top: 50%;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-left-color: #fff;
  }
  .wa-float__tooltip span {
    font-size: .82rem;
    font-weight: 600;
    color: #1a1a1a;
  }
  .wa-float__tooltip-close {
    background: none; border: none;
    font-size: 1.1rem; color: #94a3b8;
    cursor: pointer; padding: 0; line-height: 1;
    transition: color .2s;
  }
  .wa-float__tooltip-close:hover { color: #64748b; }

  /* En paginas de productos: mover a la izquierda */
  .wa-float--left {
    right: auto;
    left: 28px;
  }
  .wa-float--left .wa-float__tooltip {
    right: auto;
    left: 72px;
  }
  .wa-float--left .wa-float__tooltip::after {
    right: auto;
    left: -6px;
    border-left-color: transparent;
    border-right-color: #fff;
  }

  @media (max-width: 640px) {
    .wa-float { bottom: 20px; right: 20px; }
    .wa-float--left { right: auto; left: 20px; }
    .wa-float__btn { width: 52px; height: 52px; }
    .wa-float__icon { width: 24px; height: 24px; }
    .wa-float__tooltip { right: 62px; }
    .wa-float--left .wa-float__tooltip { right: auto; left: 62px; }
  }
</style>

<script>
  const waFloat = document.getElementById('wa-float');
  const waTooltip = waFloat?.querySelector('.wa-float__tooltip');
  const waTooltipClose = document.getElementById('wa-tooltip-close');

  if (waFloat && waTooltip) {
    // En páginas de productos, mover a la izquierda para no chocar con el cart drawer
    if (window.location.pathname.startsWith('/productos')) {
      waFloat.classList.add('wa-float--left');
    }

    let shown = false;

    function showButton() {
      if (shown) return;
      shown = true;
      waFloat!.classList.add('is-visible');

      // Show tooltip after button appears
      setTimeout(() => {
        waTooltip!.classList.add('is-visible');

        // Auto-hide tooltip after 5 seconds
        setTimeout(() => {
          waTooltip!.classList.remove('is-visible');
        }, 5000);
      }, 600);
    }

    // Show after scroll
    window.addEventListener('scroll', () => {
      if (window.scrollY > 200) showButton();
    }, { passive: true });

    // Also show after 2 seconds
    setTimeout(showButton, 2000);

    // Close tooltip manually
    waTooltipClose?.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      waTooltip!.classList.remove('is-visible');
    });
  }
</script>
