---
const menuItems = [
  { label: 'Inicio',    href: '/' },
  { label: 'Nosotros',  href: '/nosotros' },
  {
    label: 'Productos',
    href: '/productos',
    submenu: [
      { label: 'Línea Estándar',      href: '/productos' },
      { label: 'Línea Impresa',       href: '/productos/linea-impresa' },
      { label: 'Línea Personalizada', href: '/productos/linea-personalizada' },
    ],
  },
  { label: 'Contacto',  href: '/contacto' },
];
---

<header id="site-header" class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="header-logo">
      <img src="/images/logos/logo-web.png" alt="RecoPlas" class="logo-img" />
    </a>

    <!-- Nav desktop -->
    <nav class="header-nav">
      {menuItems.map((item) => (
        item.submenu ? (
          <div class="nav-dropdown">
            <a href={item.href} class="nav-link nav-link--has-sub">
              {item.label}
              <svg class="nav-chevron" width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
              </svg>
            </a>
            <div class="nav-dropdown__menu">
              {item.submenu.map((sub) => (
                <a href={sub.href} class="nav-dropdown__link">{sub.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="nav-link">{item.label}</a>
        )
      ))}
    </nav>

    <!-- Acciones derecha -->
    <div class="header-actions">

      <!-- Buscador inline -->
      <div class="search-bar">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="search-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
        </svg>
        <input type="text" placeholder="Buscar productos..." class="search-input" />
      </div>

      <!-- Cuenta -->
      <a href="/mi-cuenta" class="header-account">
        <svg width="17" height="17" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span>Cuenta</span>
      </a>

      <!-- Carrito -->
      <button id="header-cart-btn" class="header-cart-btn" aria-label="Carrito">
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
        </svg>
        <span id="header-cart-badge" class="cart-badge hidden">0</span>
      </button>

      <!-- Burger móvil -->
      <button id="menu-toggle" class="header-burger" aria-label="Menú">
        <span></span><span></span><span></span>
      </button>

    </div>
  </div>

  <!-- Menú móvil -->
  <div id="mobile-menu" class="mobile-menu hidden">
    <div class="mobile-search">
      <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
      </svg>
      <input type="text" placeholder="Buscar productos..." />
    </div>
    {menuItems.map((item) => (
      item.submenu ? (
        <div class="mobile-dropdown">
          <button class="mobile-link mobile-link--has-sub" data-mobile-dropdown>
            {item.label}
            <svg class="mobile-chevron" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="mobile-dropdown__menu hidden">
            <a href={item.href} class="mobile-dropdown__link">Ver todos</a>
            {item.submenu.map((sub) => (
              <a href={sub.href} class="mobile-dropdown__link">{sub.label}</a>
            ))}
          </div>
        </div>
      ) : (
        <a href={item.href} class="mobile-link">{item.label}</a>
      )
    ))}
    <a href="/mi-cuenta" class="mobile-link">Cuenta</a>
    <a href="/contacto" class="mobile-cta">Solicitar Presupuesto</a>
  </div>
</header>

<div class="header-spacer"></div>

<style>
  :root {
    --header-h: 80px;
    --g:  #00AA28;
    --gd: #008f22;
    --blue: #1a3f8f;
    --dk: #1a1a1a;
    --gr: #64748b;
    --border: #e5e7eb;
  }

  /* ── Base ── */
  .site-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 500;
    height: var(--header-h);
    background: #fff;
    border-bottom: 1px solid var(--border);
    transition: box-shadow .3s ease;
  }
  .site-header.scrolled {
    box-shadow: 0 2px 16px rgba(0,0,0,.08);
  }

  .header-inner {
    max-width: 1280px; margin: 0 auto;
    padding: 0 2.5rem;
    height: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  /* ── Logo ── */
  .header-logo { flex-shrink: 0; display: flex; align-items: center; }
  .logo-img {
    height: 56px; width: auto;
    transition: opacity .2s;
  }
  .header-logo:hover .logo-img { opacity: .85; }

  /* ── Nav ── */
  .header-nav {
    display: none; align-items: center; justify-content: center; gap: .1rem;
  }
  @media (min-width: 1024px) { .header-nav { display: flex; } }

  .nav-link {
    padding: .5rem 1.1rem;
    font-size: .9rem; font-weight: 500; color: var(--dk);
    text-decoration: none; border-radius: 7px;
    transition: color .2s, background .2s;
  }
  .nav-link:hover { color: var(--g); background: #f0fdf4; }
  .nav-link.active { color: var(--g); font-weight: 700; }

  /* Dropdown desktop */
  .nav-dropdown { position: relative; }
  .nav-link--has-sub {
    display: inline-flex; align-items: center; gap: .3rem;
  }
  .nav-chevron {
    transition: transform .25s ease;
  }
  .nav-dropdown:hover .nav-chevron { transform: rotate(180deg); }

  .nav-dropdown__menu {
    position: absolute; top: 100%; left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 210px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 12px 36px rgba(0,0,0,.1);
    padding: .5rem;
    opacity: 0; visibility: hidden;
    transition: opacity .2s ease, transform .2s ease, visibility .2s;
  }
  .nav-dropdown:hover .nav-dropdown__menu {
    opacity: 1; visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .nav-dropdown__link {
    display: block;
    padding: .6rem 1rem;
    font-size: .85rem; font-weight: 500; color: var(--dk);
    text-decoration: none; border-radius: 8px;
    transition: background .2s, color .2s;
  }
  .nav-dropdown__link:hover { background: #f0fdf4; color: var(--g); }

  /* ── Acciones ── */
  .header-actions {
    display: flex; align-items: center; justify-content: flex-end; gap: .6rem;
  }

  /* Buscador */
  .search-bar {
    display: none; align-items: center; gap: .5rem;
    background: #f8fafc; border: 1px solid var(--border);
    border-radius: 9px; padding: .45rem .9rem;
    width: 220px; transition: border-color .2s, box-shadow .2s;
  }
  .search-bar:focus-within {
    border-color: var(--g);
    box-shadow: 0 0 0 3px rgba(0,170,40,.1);
    width: 260px;
  }
  @media (min-width: 768px) { .search-bar { display: flex; transition: width .3s ease, border-color .2s, box-shadow .2s; } }

  .search-icon { color: var(--gr); flex-shrink: 0; }
  .search-input {
    flex: 1; border: none; outline: none; background: transparent;
    font-size: .82rem; color: var(--dk);
  }
  .search-input::placeholder { color: #94a3b8; }

  /* Cuenta */
  .header-account {
    display: none; align-items: center; gap: .4rem;
    padding: .45rem .7rem;
    color: var(--dk); text-decoration: none;
    font-size: .82rem; font-weight: 500;
    border-radius: 8px; border: 1px solid var(--border);
    transition: border-color .2s, color .2s, background .2s;
    white-space: nowrap;
  }
  .header-account:hover { border-color: var(--g); color: var(--g); background: #f0fdf4; }
  @media (min-width: 640px) { .header-account { display: inline-flex; } }

  /* Carrito -->  */
  .header-cart-btn {
    position: relative;
    width: 38px; height: 38px; border-radius: 9px; border: none;
    background: var(--g); color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; flex-shrink: 0;
    transition: background .2s, transform .15s;
  }
  .header-cart-btn:hover { background: var(--gd); transform: scale(1.06); }

  .cart-badge {
    position: absolute; top: -5px; right: -5px;
    min-width: 18px; height: 18px; border-radius: 999px;
    padding: 0 4px;
    background: #ef4444; color: #fff;
    font-size: .62rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    border: 2px solid #fff;
  }
  .cart-badge.hidden { display: none; }

  /* Burger */
  .header-burger {
    display: flex; flex-direction: column; justify-content: center; gap: 5px;
    background: none; border: none; cursor: pointer;
    padding: .4rem; border-radius: 7px;
    transition: background .2s;
  }
  .header-burger:hover { background: #f1f5f9; }
  .header-burger span {
    display: block; width: 20px; height: 2px;
    background: var(--dk); border-radius: 2px;
  }
  @media (min-width: 1024px) { .header-burger { display: none; } }
  @media (max-width: 480px) {
    .header-inner { padding: 0 1rem; gap: 1rem; }
    .logo-img { height: 44px; }
  }

  /* Mobile menu */
  .mobile-menu {
    background: #fff; border-top: 1px solid var(--border);
    padding: .75rem 1.5rem 1.25rem;
    display: flex; flex-direction: column; gap: .2rem;
  }
  .mobile-menu.hidden { display: none; }

  .mobile-search {
    display: flex; align-items: center; gap: .5rem;
    background: #f8fafc; border: 1px solid var(--border);
    border-radius: 9px; padding: .55rem .9rem;
    margin-bottom: .5rem;
    color: var(--gr);
  }
  .mobile-search input {
    flex: 1; border: none; outline: none; background: transparent;
    font-size: .875rem; color: var(--dk);
  }
  .mobile-search input::placeholder { color: #94a3b8; }

  .mobile-link {
    padding: .7rem 1rem; color: var(--dk);
    font-size: .9rem; font-weight: 500;
    text-decoration: none; border-radius: 8px;
    transition: background .2s, color .2s;
  }
  .mobile-link:hover { background: #f0fdf4; color: var(--g); }

  .mobile-link--has-sub {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; background: none; border: none; cursor: pointer;
    font-family: inherit;
  }
  .mobile-chevron { transition: transform .25s ease; }
  .mobile-link--has-sub.open .mobile-chevron { transform: rotate(180deg); }

  .mobile-dropdown__menu {
    display: flex; flex-direction: column; gap: .1rem;
    padding-left: 1rem;
  }
  .mobile-dropdown__menu.hidden { display: none; }
  .mobile-dropdown__link {
    padding: .55rem 1rem;
    font-size: .85rem; font-weight: 500; color: var(--gr);
    text-decoration: none; border-radius: 8px;
    transition: background .2s, color .2s;
  }
  .mobile-dropdown__link:hover { background: #f0fdf4; color: var(--g); }

  .mobile-cta {
    margin-top: .5rem; padding: .8rem 1rem;
    background: var(--g); color: #fff;
    font-weight: 700; font-size: .875rem;
    border-radius: 10px; text-decoration: none; text-align: center;
    transition: background .2s;
  }
  .mobile-cta:hover { background: var(--gd); }

  .header-spacer { height: var(--header-h); }
</style>

<script>
  // Scroll shadow
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  // Mobile toggle
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  menuToggle?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.toggle('hidden');
    document.body.style.overflow = isHidden ? '' : 'hidden';
  });

  // Mobile dropdown toggle
  document.querySelectorAll('[data-mobile-dropdown]').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('open');
      btn.nextElementSibling?.classList.toggle('hidden');
    });
  });

  // Active nav link
  document.querySelectorAll('.nav-link').forEach(link => {
    if ((link as HTMLAnchorElement).pathname === window.location.pathname) {
      link.classList.add('active');
    }
  });

  // Cart badge sync
  function syncBadge() {
    try {
      const cart = JSON.parse(localStorage.getItem('rp-cart') || '[]');
      const total = (cart as any[]).reduce((s, i) => s + i.cantidad, 0);
      const badge = document.getElementById('header-cart-badge');
      if (badge) {
        badge.textContent = String(total);
        badge.classList.toggle('hidden', total === 0);
      }
    } catch {}
  }
  syncBadge();
  window.addEventListener('storage', syncBadge);
  document.addEventListener('cart-updated', syncBadge);

  // Open cart drawer
  document.getElementById('header-cart-btn')?.addEventListener('click', () => {
    document.getElementById('cart-drawer')?.classList.add('open');
    document.getElementById('cart-overlay')?.classList.add('open');
    document.body.style.overflow = 'hidden';
  });

  // Search — redirect to /productos with search param
  function handleSearch(input: HTMLInputElement) {
    const query = input.value.trim();
    if (query.length > 0) {
      window.location.href = `/productos?buscar=${encodeURIComponent(query)}#catalogo`;
    }
  }

  // Desktop search
  const desktopSearch = document.querySelector('.search-bar .search-input') as HTMLInputElement;
  desktopSearch?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      handleSearch(desktopSearch);
    }
  });

  // Mobile search
  const mobileSearch = document.querySelector('.mobile-search input') as HTMLInputElement;
  mobileSearch?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      handleSearch(mobileSearch);
    }
  });
</script>
