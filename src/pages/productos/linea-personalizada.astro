---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const img = (name: string) => `/images/linea-personalizada/${encodeURIComponent(name)}`;

const trabajos = [
  { src: img('A medida_resultado.webp'), cliente: 'Hielo Real', rubro: 'Fábrica de hielo' },
  { src: img('A medida 2_resultado.webp'), cliente: 'Hielo Real', rubro: 'Fábrica de hielo' },
  { src: img('A medida 3_resultado.webp'), cliente: 'Hielo Real', rubro: 'Fábrica de hielo' },
  { src: img('A medida 4_resultado.webp'), cliente: 'Hielo Real', rubro: 'Fábrica de hielo' },
  { src: img('A medida 5_resultado.webp'), cliente: 'Hielo Real', rubro: 'Fábrica de hielo' },
  { src: img('BOLSAS IMPRESAS ESTANDAR_resultado.webp'), cliente: 'Carbón Vegetal', rubro: 'Carbonería' },
  { src: img('BOLSAS IMPRESAS ESTANDAR_1_resultado.webp'), cliente: 'Carbón Vegetal', rubro: 'Carbonería' },
  { src: img('BOLSAS IMPRESAS ESTANDAR_2_resultado.webp'), cliente: 'Carbón Vegetal', rubro: 'Carbonería' },
];

const ventajas = [
  { icon: 'M4 8V4a2 2 0 012-2h2M4 16v4a2 2 0 002 2h2m8-20h2a2 2 0 012 2v2m0 12v2a2 2 0 01-2 2h-2', titulo: 'Medida y espesor a elección', desc: 'Definimos las dimensiones exactas y el grosor del material según el uso de destino.' },
  { icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', titulo: 'Material adaptado', desc: 'Alta densidad, baja densidad o termocontraíble. Elegimos el mejor para tu producto.' },
  { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', titulo: 'Diseño e impresión', desc: 'Flexografía de hasta 4 colores. Tu marca, logo y datos impresos con calidad profesional.' },
];

const WA_NUMBER = '543482200375';
---

<Layout title="Línea Personalizada | RecoPlas" description="Empaques de polietileno a medida para tu industria. Definimos material, forma, medida e impresión. Pedí tu presupuesto.">
  <Header />

  <!-- ========== HERO ========== -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__orb hero__orb--1"></div>
      <div class="hero__orb hero__orb--2"></div>
    </div>

    <div class="hero__container">
      <div class="hero__content">
        <div class="hero__badge" data-anim="fade-up">
          <span class="hero__badge-dot"></span>
          Línea Personalizada
        </div>

        <h1 class="hero__title" data-anim="fade-up" data-delay="100">
          Empaques a
          <span class="hero__title-accent">tu medida</span>
        </h1>

        <p class="hero__text" data-anim="fade-up" data-delay="200">
          Desarrollamos bolsas y film personalizados para tu industria.
          Vos elegís medida, material, forma e impresión. Nosotros lo fabricamos.
        </p>

        <div class="hero__actions" data-anim="fade-up" data-delay="300">
          <a href="#consulta" class="rp-btn rp-btn--green">
            Quiero mi empaque a medida
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </a>
          <a href="#trabajos" class="rp-btn rp-btn--ghost">
            Ver trabajos
          </a>
        </div>
      </div>

      <div class="hero__visual" data-anim="fade-left" data-delay="200">
        <div class="hero__img-wrap">
          <img src={img('A medida 4_resultado.webp')} alt="Bolsa personalizada RecoPlas - Hielo Real" />
        </div>
        <div class="hero__floating-card">
          <div class="hero__floating-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <div>
            <p class="hero__floating-title">Producto a medida</p>
            <p class="hero__floating-sub">Medida, material y diseño</p>
          </div>
        </div>
      </div>
    </div>

    <div class="hero__wave">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- ========== VENTAJAS ========== -->
  <section class="ventajas">
    <div class="ventajas__container">
      <div class="ventajas__head" data-anim="fade-up">
        <span class="chip-label">¿Qué personalizamos?</span>
        <h2 class="sec-title">
          Cada detalle,
          <span class="sec-title--g">a tu elección</span>
        </h2>
        <p class="sec-sub">Láminas y bolsas en alta y baja densidad, impresas o sin impresión, incluyendo material termocontraíble.</p>
      </div>
      <div class="ventajas__grid">
        {ventajas.map((v, i) => (
          <div class="ventaja-card" data-anim="fade-up" data-delay={String(i * 120)}>
            <div class="ventaja-card__icon">
              <svg width="26" height="26" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={v.icon}/></svg>
            </div>
            <h3 class="ventaja-card__title">{v.titulo}</h3>
            <p class="ventaja-card__desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== GALERÍA TRABAJOS ========== -->
  <section class="trabajos" id="trabajos">
    <div class="trabajos__container">
      <div class="trabajos__head" data-anim="fade-up">
        <span class="chip-label">Trabajos realizados</span>
        <h2 class="sec-title">
          Casos reales de
          <span class="sec-title--g">productos a medida</span>
        </h2>
        <p class="sec-sub">Algunos ejemplos de empaques personalizados que fabricamos para nuestros clientes.</p>
      </div>

      <div class="trabajos__gallery">
        {trabajos.map((t, i) => (
          <button class="trabajos__item" data-lightbox={t.src} data-anim="fade-up" data-delay={String((i % 4) * 80)}>
            <img src={t.src} alt={`Empaque personalizado - ${t.cliente}`} loading="lazy" />
            <div class="trabajos__overlay">
              <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
              <span class="trabajos__overlay-name">{t.cliente}</span>
              <span class="trabajos__overlay-rubro">{t.rubro}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== FORMULARIO CONSULTA ========== -->
  <section class="consulta" id="consulta">
    <div class="consulta__container">
      <div class="consulta__grid">
        <div class="consulta__info" data-anim="fade-right">
          <span class="chip-label chip-label--white">Consúltanos</span>
          <h2 class="sec-title sec-title--white">
            ¿Necesitás un empaque
            <span class="consulta__accent">a tu medida?</span>
          </h2>
          <p class="consulta__desc">
            Dejanos tus datos y nos ponemos en contacto para asesorarte.
            Definimos juntos medida, material, forma, diseño y cantidad de colores.
          </p>
          <div class="consulta__features">
            <div class="consulta__feature">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Asesoramiento sin compromiso
            </div>
            <div class="consulta__feature">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Presupuesto en 24hs
            </div>
            <div class="consulta__feature">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Envíos a todo el país
            </div>
          </div>
        </div>

        <div class="consulta__form-wrap" data-anim="fade-left">
          <form id="consulta-form" class="consulta__form">
            <div class="consulta__field">
              <label for="nombre">Nombre / Empresa</label>
              <input type="text" id="nombre" name="nombre" placeholder="Ej: Hielo Real S.A." required />
            </div>
            <div class="consulta__field">
              <label for="telefono">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" placeholder="Ej: 3482 123456" required />
            </div>
            <div class="consulta__field">
              <label for="email">Email (opcional)</label>
              <input type="email" id="email" name="email" placeholder="correo@ejemplo.com" />
            </div>
            <div class="consulta__field">
              <label for="mensaje">¿Qué necesitás?</label>
              <textarea id="mensaje" name="mensaje" rows="3" placeholder="Contanos qué producto necesitás: medida, material, si lleva impresión, cantidad..."></textarea>
            </div>
            <button type="submit" class="rp-btn rp-btn--green consulta__submit">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Enviar por WhatsApp
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox">
    <button class="lightbox__close" aria-label="Cerrar">
      <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button class="lightbox__nav lightbox__nav--prev" aria-label="Anterior">
      <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button class="lightbox__nav lightbox__nav--next" aria-label="Siguiente">
      <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
    <div class="lightbox__img-wrap">
      <img id="lightbox-img" src="" alt="" />
    </div>
    <div class="lightbox__counter" id="lightbox-counter"></div>
  </div>

  <Footer />
</Layout>

<style>
/* ====== VARIABLES ====== */
:root {
  --g: #00AA28;
  --gd: #008f22;
  --gl: #33cc52;
  --gp: #e8f9ed;
  --dk: #1a1a1a;
  --gr: #64748b;
  --gl-bg: #f8faf9;
  --r: 16px;
  --rl: 24px;
  --ease: .45s cubic-bezier(.23,1,.32,1);
}

/* ====== HERO ====== */
.hero {
  position: relative;
  min-height: 90vh;
  display: flex; align-items: center;
  overflow: hidden;
  padding-bottom: 5rem;
}
.hero__bg { position: absolute; inset: 0; }
.hero__gradient {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--dk) 0%, #1e293b 50%, rgba(0,170,40,.12) 100%);
}
.hero__orb {
  position: absolute; border-radius: 50%;
  filter: blur(80px); pointer-events: none;
}
.hero__orb--1 {
  top: -10%; left: -5%;
  width: 500px; height: 500px;
  background: var(--g); opacity: .06;
}
.hero__orb--2 {
  bottom: -15%; right: -5%;
  width: 600px; height: 600px;
  background: var(--g); opacity: .04;
}
.hero__container {
  position: relative; z-index: 2;
  max-width: 1280px; margin: 0 auto;
  padding: 0 2rem;
  display: grid; grid-template-columns: 1.4fr 1fr;
  gap: 3rem; align-items: center;
  width: 100%;
}
.hero__badge {
  display: inline-flex; align-items: center; gap: .5rem;
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(10px);
  padding: .5rem 1.2rem; border-radius: 999px;
  margin-bottom: 1.5rem;
  color: rgba(255,255,255,.85); font-size: .82rem; font-weight: 600;
  border: 1px solid rgba(255,255,255,.08);
}
.hero__badge-dot {
  width: 8px; height: 8px;
  background: var(--g); border-radius: 50%;
  animation: pulse-dot 2s ease-in-out infinite;
}
.hero__title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(2.2rem, 4.5vw, 3.5rem);
  font-weight: 800; line-height: 1.1;
  color: #fff; margin: 0 0 1.5rem;
}
.hero__title-accent {
  display: block;
  background: linear-gradient(135deg, var(--g) 0%, #00dd35 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero__text {
  font-size: 1.05rem; line-height: 1.8;
  color: rgba(255,255,255,.65);
  margin: 0 0 2rem; max-width: 520px;
}
.hero__actions { display: flex; flex-wrap: wrap; gap: 1rem; }

.hero__visual { display: none; position: relative; }
.hero__img-wrap {
  border-radius: 24px; overflow: hidden;
  box-shadow: 0 30px 60px rgba(0,0,0,.3);
  border: 1px solid rgba(255,255,255,.06);
}
.hero__img-wrap img {
  display: block; width: 100%; height: 420px; object-fit: cover;
}
.hero__floating-card {
  position: absolute; bottom: 2rem; left: -2rem;
  background: #fff; border-radius: 14px;
  padding: 1rem 1.25rem;
  box-shadow: 0 15px 40px rgba(0,0,0,.15);
  display: flex; align-items: center; gap: .75rem;
  animation: float-card 4s ease-in-out infinite;
  z-index: 3;
}
.hero__floating-icon {
  width: 40px; height: 40px; border-radius: 10px;
  background: var(--gp);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.hero__floating-icon svg { width: 20px; height: 20px; color: var(--g); }
.hero__floating-title { font-weight: 700; font-size: .82rem; color: var(--dk); margin: 0; }
.hero__floating-sub { font-size: .72rem; color: var(--gr); margin: 0; }

.hero__wave {
  position: absolute; bottom: 0; left: 0; right: 0;
  z-index: 3; line-height: 0;
}
.hero__wave svg { width: 100%; height: auto; display: block; }

@media (min-width: 1024px) { .hero__visual { display: block; } }
@media (max-width: 1023px) {
  .hero__container { grid-template-columns: 1fr; }
  .hero__title { font-size: clamp(2.4rem, 8vw, 3rem); }
  .hero__content { text-align: center; }
  .hero__text { margin-left: auto; margin-right: auto; }
  .hero__actions { justify-content: center; }
  .hero__badge { margin-left: auto; margin-right: auto; }
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: .5; transform: scale(1.3); }
}
@keyframes float-card {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

/* ====== SHARED ====== */
.chip-label {
  display: inline-block;
  font-size: .75rem; font-weight: 800; letter-spacing: .15em; text-transform: uppercase;
  color: var(--g); background: var(--gp);
  padding: .4rem 1rem; border-radius: 999px; margin-bottom: .75rem;
}
.chip-label--white { color: #fff; background: rgba(255,255,255,.15); }
.sec-title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.75rem);
  font-weight: 800; line-height: 1.15; color: var(--dk);
  margin: 0 0 1rem;
}
.sec-title--white { color: #fff; }
.sec-title--g { color: var(--g); }
.sec-sub { color: var(--gr); font-size: 1.05rem; max-width: 520px; margin: 0 auto; line-height: 1.65; }

/* ====== BUTTONS ====== */
.rp-btn {
  display: inline-flex !important; align-items: center; justify-content: center; gap: .5rem;
  font-family: 'Open Sans', sans-serif; font-weight: 700; font-size: .92rem; line-height: 1;
  padding: .9rem 2rem; border-radius: 999px; border: 2px solid transparent;
  text-decoration: none !important; cursor: pointer; transition: var(--ease);
}
.rp-btn--green {
  background: var(--g) !important; color: #fff !important; border-color: var(--g) !important;
  box-shadow: 0 4px 15px rgba(0,170,40,.3);
}
.rp-btn--green:hover {
  background: var(--gd) !important; border-color: var(--gd) !important;
  transform: translateY(-3px); box-shadow: 0 8px 30px rgba(0,170,40,.45);
}
.rp-btn--ghost {
  background: transparent !important; color: #fff !important;
  border-color: rgba(255,255,255,.4) !important;
}
.rp-btn--ghost:hover {
  border-color: #fff !important; background: rgba(255,255,255,.1) !important;
  transform: translateY(-3px);
}

/* ====== ANIMATIONS ====== */
[data-anim] {
  opacity: 0;
  transition: opacity .8s var(--ease), transform .8s var(--ease);
}
[data-anim="fade-up"] { transform: translateY(50px); }
[data-anim="fade-left"] { transform: translateX(50px); }
[data-anim="fade-right"] { transform: translateX(-50px); }
[data-anim].is-visible {
  opacity: 1 !important;
  transform: translate(0, 0) !important;
}

/* ====== VENTAJAS ====== */
.ventajas { padding: 3rem 0 5rem; background: #fff; }
.ventajas__container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
.ventajas__head { text-align: center; margin-bottom: 3.5rem; }
.ventajas__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }

.ventaja-card {
  background: var(--gl-bg); border: 1px solid #e5e7eb;
  border-radius: var(--rl); padding: 2rem 1.75rem;
  transition: var(--ease);
}
.ventaja-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 50px rgba(0,170,40,.1);
  border-color: rgba(0,170,40,.2);
}
.ventaja-card__icon {
  width: 52px; height: 52px; border-radius: 14px;
  background: var(--gp); color: var(--g);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.25rem; transition: var(--ease);
}
.ventaja-card:hover .ventaja-card__icon {
  background: var(--g); color: #fff;
  transform: scale(1.1) rotate(-3deg);
}
.ventaja-card__title {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.1rem; font-weight: 700; color: var(--dk); margin: 0 0 .5rem;
}
.ventaja-card__desc { font-size: .88rem; color: var(--gr); line-height: 1.65; margin: 0; }

/* ====== TRABAJOS ====== */
.trabajos { padding: 5rem 0; background: var(--gl-bg); }
.trabajos__container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
.trabajos__head { text-align: center; margin-bottom: 3.5rem; }

.trabajos__gallery {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
}
.trabajos__item {
  position: relative; border-radius: var(--r); overflow: hidden;
  cursor: pointer; border: none; padding: 0; background: #fff;
  box-shadow: 0 4px 20px rgba(0,0,0,.06);
  transition: var(--ease);
  aspect-ratio: 3/4;
}
.trabajos__item:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(0,0,0,.12);
}
.trabajos__item img {
  display: block; width: 100%; height: 100%;
  object-fit: cover; transition: transform .6s ease;
}
.trabajos__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.75) 0%, transparent 50%);
  display: flex; flex-direction: column; justify-content: flex-end;
  align-items: flex-start; padding: 1.25rem;
  opacity: 0; transition: opacity .3s ease;
  color: #fff;
}
.trabajos__overlay svg {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  opacity: .8;
}
.trabajos__overlay-name {
  font-weight: 700; font-size: .9rem;
}
.trabajos__overlay-rubro {
  font-size: .75rem; opacity: .7;
}
.trabajos__item:hover .trabajos__overlay { opacity: 1; }
.trabajos__item:hover img { transform: scale(1.05); }

/* ====== CONSULTA ====== */
.consulta {
  padding: 5rem 0;
  background: linear-gradient(160deg, var(--dk) 0%, #1e293b 100%);
}
.consulta__container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
.consulta__grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 4rem; align-items: center;
}

.consulta__accent {
  color: var(--gl);
}
.consulta__desc {
  color: rgba(255,255,255,.6); font-size: 1.05rem; line-height: 1.8;
  margin: 0 0 2rem;
}
.consulta__features { display: flex; flex-direction: column; gap: .75rem; }
.consulta__feature {
  display: flex; align-items: center; gap: .6rem;
  color: rgba(255,255,255,.7); font-size: .9rem; font-weight: 500;
}
.consulta__feature svg { color: var(--g); flex-shrink: 0; }

/* Form */
.consulta__form-wrap {
  background: #fff; border-radius: var(--rl);
  padding: 2.5rem; box-shadow: 0 25px 60px rgba(0,0,0,.2);
}
.consulta__form { display: flex; flex-direction: column; gap: 1.25rem; }
.consulta__field label {
  display: block; font-size: .82rem; font-weight: 700;
  color: var(--dk); margin-bottom: .4rem;
}
.consulta__field input,
.consulta__field textarea {
  width: 100%; padding: .75rem 1rem;
  border: 1px solid #e5e7eb; border-radius: 12px;
  font-size: .9rem; color: var(--dk);
  font-family: 'Open Sans', sans-serif;
  transition: border-color .2s, box-shadow .2s;
  background: #f8fafc;
  box-sizing: border-box;
}
.consulta__field input:focus,
.consulta__field textarea:focus {
  outline: none; border-color: var(--g);
  box-shadow: 0 0 0 3px rgba(0,170,40,.1);
}
.consulta__field textarea { resize: vertical; min-height: 80px; }
.consulta__submit { width: 100%; justify-content: center; }

/* ====== LIGHTBOX ====== */
.lightbox {
  position: fixed; inset: 0; z-index: 9999;
  background: rgba(0,0,0,.92); backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; visibility: hidden;
  transition: opacity .3s ease, visibility .3s ease;
}
.lightbox.is-open { opacity: 1; visibility: visible; }

.lightbox__close {
  position: absolute; top: 1.5rem; right: 1.5rem;
  background: rgba(255,255,255,.1); border: none; border-radius: 50%;
  width: 48px; height: 48px;
  display: flex; align-items: center; justify-content: center;
  color: #fff; cursor: pointer; transition: background .2s;
}
.lightbox__close:hover { background: rgba(255,255,255,.25); }

.lightbox__nav {
  position: absolute; top: 50%; transform: translateY(-50%);
  background: rgba(255,255,255,.1); border: none; border-radius: 50%;
  width: 52px; height: 52px;
  display: flex; align-items: center; justify-content: center;
  color: #fff; cursor: pointer; transition: background .2s;
}
.lightbox__nav:hover { background: rgba(255,255,255,.25); }
.lightbox__nav--prev { left: 1.5rem; }
.lightbox__nav--next { right: 1.5rem; }

.lightbox__img-wrap {
  max-width: 85vw; max-height: 85vh;
  display: flex; align-items: center; justify-content: center;
}
.lightbox__img-wrap img {
  max-width: 100%; max-height: 85vh;
  border-radius: 12px; object-fit: contain;
  box-shadow: 0 20px 60px rgba(0,0,0,.5);
  transition: opacity .25s ease;
}
.lightbox__counter {
  position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
  color: rgba(255,255,255,.6); font-size: .85rem; font-weight: 600;
}

/* ====== RESPONSIVE ====== */
@media (max-width: 1024px) {
  .ventajas__grid { grid-template-columns: 1fr; }
  .trabajos__gallery { grid-template-columns: repeat(3, 1fr); }
  .consulta__grid { grid-template-columns: 1fr; gap: 2.5rem; }
}
@media (max-width: 640px) {
  .hero { min-height: 65vh; padding-bottom: 3rem; }
  .hero__container { padding: 0 1.25rem; }
  .hero__img-wrap img { height: clamp(250px, 50vw, 420px); }
  .ventajas { padding: 3rem 0 3.5rem; }
  .ventajas__container { padding: 0 1.25rem; }
  .trabajos { padding: 3rem 0 3.5rem; }
  .trabajos__container { padding: 0 1.25rem; }
  .trabajos__gallery { grid-template-columns: repeat(2, 1fr); }
  .consulta { padding: 3rem 0 3.5rem; }
  .consulta__container { padding: 0 1.25rem; }
  .consulta__form-wrap { padding: 1.5rem; }
  .consulta__field label { font-size: .85rem; }
  .consulta__field input, .consulta__field textarea { font-size: .95rem; }
  .rp-btn { font-size: .88rem; padding: .8rem 1.6rem; }
  .hero__floating-sub { font-size: .78rem; }
  .lightbox__nav { width: 40px; height: 40px; }
  .lightbox__nav--prev { left: .75rem; }
  .lightbox__nav--next { right: .75rem; }
}
</style>

<script define:vars={{ WA_NUMBER }}>
  // ===== Scroll Animations =====
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const delay = el.dataset.delay || '0';
          setTimeout(() => el.classList.add('is-visible'), parseInt(delay));
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-anim]').forEach((el) => observer.observe(el));

  // ===== Lightbox =====
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxCounter = document.getElementById('lightbox-counter');
  const items = document.querySelectorAll('[data-lightbox]');
  const srcs = Array.from(items).map(el => el.dataset.lightbox);
  let currentIdx = 0;

  function openLightbox(idx) {
    currentIdx = idx;
    lightboxImg.src = srcs[currentIdx];
    lightboxImg.alt = items[currentIdx].querySelector('img')?.alt || '';
    if (lightboxCounter) lightboxCounter.textContent = `${currentIdx + 1} / ${srcs.length}`;
    lightbox?.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  function navigate(dir) {
    currentIdx = (currentIdx + dir + srcs.length) % srcs.length;
    lightboxImg.style.opacity = '0';
    setTimeout(() => {
      lightboxImg.src = srcs[currentIdx];
      lightboxImg.alt = items[currentIdx].querySelector('img')?.alt || '';
      if (lightboxCounter) lightboxCounter.textContent = `${currentIdx + 1} / ${srcs.length}`;
      lightboxImg.style.opacity = '1';
    }, 150);
  }

  items.forEach((item, i) => item.addEventListener('click', () => openLightbox(i)));
  document.querySelector('.lightbox__close')?.addEventListener('click', closeLightbox);
  document.querySelector('.lightbox__nav--prev')?.addEventListener('click', () => navigate(-1));
  document.querySelector('.lightbox__nav--next')?.addEventListener('click', () => navigate(1));
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target.classList.contains('lightbox__img-wrap')) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });

  // ===== WhatsApp Form =====
  document.getElementById('consulta-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target;
    const nombre = form.nombre.value.trim();
    const telefono = form.telefono.value.trim();
    const email = form.email.value.trim();
    const mensaje = form.mensaje.value.trim();

    let text = `*Consulta Línea Personalizada - RecoPlas*\n\n`;
    text += `*Nombre/Empresa:* ${nombre}\n`;
    text += `*Teléfono:* ${telefono}\n`;
    if (email) text += `*Email:* ${email}\n`;
    if (mensaje) text += `\n*Mensaje:*\n${mensaje}\n`;

    const url = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(text)}`;
    window.open(url, '_blank');
  });
</script>
