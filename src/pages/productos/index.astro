---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProductos, getCategorias, formatPrice } from '../../lib/wordpress';

const productos = await getProductos();
const categorias = await getCategorias();

// Filtrar categorías que tengan productos y no sean "sin categorizar"
const categoriasActivas = categorias.filter(c => c.count > 0 && c.slug !== 'sin-categorizar');
---

<Layout title="Productos | Reco-Plas" description="Catálogo de bolsas de polietileno: camiseta, consorcio, residuo, bobinas de arranque, emblocadas y láminas. Precios y envíos a todo el país.">
  <Header />

  <!-- ========== HERO ========== -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__orb hero__orb--1"></div>
      <div class="hero__orb hero__orb--2"></div>
    </div>

    <div class="hero__container">
      <div class="hero__content">
        <div class="hero__badge" data-anim="fade-up">
          <span class="hero__badge-dot"></span>
          Catálogo de Productos
        </div>

        <h1 class="hero__title" data-anim="fade-up" data-delay="100">
          Nuestros
          <span class="hero__title-accent">productos</span>
        </h1>

        <p class="hero__text" data-anim="fade-up" data-delay="200">
          Fabricación propia de bolsas de polietileno con envíos a todo el país.
          Calidad garantizada directo de fábrica.
        </p>

        <div class="hero__actions" data-anim="fade-up" data-delay="300">
          <a href="#catalogo" class="rp-btn rp-btn--green">
            Ver Catálogo
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </a>
          <a href="/contacto" class="rp-btn rp-btn--ghost">
            Pedir Cotización
          </a>
        </div>
      </div>

      <div class="hero__visual" data-anim="fade-left" data-delay="200">
        <div class="hero__img-wrap">
          <img src="/images/hero%20nuevo.webp" alt="Productos RecoPlas" />
        </div>
        <div class="hero__floating-card">
          <div class="hero__floating-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <div>
            <p class="hero__floating-title">Envíos a todo el país</p>
            <p class="hero__floating-sub">Directo de fábrica</p>
          </div>
        </div>
      </div>
    </div>

    <div class="hero__wave">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H0Z" fill="#fff"/>
      </svg>
    </div>
  </section>

  <!-- ========== CATÁLOGO ========== -->
  <section class="catalogo" id="catalogo">
    <div class="catalogo__container">

      <div class="catalogo__header" data-anim="fade-up">
        <span class="sec-label">Catálogo</span>
        <h2 class="sec-title">Explorá nuestros productos</h2>
        <p class="sec-desc">Seleccioná una categoría · Los precios son por unidad</p>
      </div>

      <!-- Filtros -->
      {categoriasActivas.length > 0 && (
        <div class="catalogo__filters" data-anim="fade-up" data-delay="100">
          <button class="cat-btn active" data-cat="todos">Todos</button>
          {categoriasActivas.map((cat) => (
            <button class="cat-btn" data-cat={cat.slug}>{cat.name}</button>
          ))}
        </div>
      )}

      <!-- Grid de productos -->
      {productos.length > 0 ? (
        <div class="catalogo__grid" id="products-grid">
          {productos.map((p) => {
            const multiploAttr = p.attributes.find(a => a.name.toLowerCase() === 'multiplo');
            const shortText = p.short_description?.replace(/<[^>]*>/g, '') || '';
            const multiploMatch = shortText.match(/mínima:\s*([\d.]+)/i);
            const multiplo = multiploAttr ? parseFloat(multiploAttr.options[0]) : (multiploMatch ? parseFloat(multiploMatch[1]) : 1);
            return (
            <article
              class="product-card"
              data-categoria={p.categories.map(c => c.slug).join(',')}
              data-id={p.id}
              data-nombre={p.name}
              data-precio={p.price}
              data-imagen={p.images[0]?.src || '/images/producto-1.webp'}
              data-multiplo={multiplo}
            >
              <a href={`/productos/${p.slug}`} class="pc-img-link">
                <div class="pc-img">
                  <img
                    src={p.images[0]?.src || '/images/producto-1.webp'}
                    alt={p.images[0]?.alt || p.name}
                    loading="lazy"
                  />
                  {p.categories[0] && p.categories[0].slug !== 'sin-categorizar' && (
                    <span class="pc-badge">{p.categories[0].name}</span>
                  )}
                </div>
              </a>

              <div class="pc-body">
                <a href={`/productos/${p.slug}`} class="pc-name-link">
                  <h3 class="pc-name">{p.name}</h3>
                </a>

                <div class="pc-price-row">
                  <span class="pc-price" data-unit-price={p.price}>{formatPrice(Number(p.price) * multiplo)}</span>
                  <span class="pc-price-unit">({formatPrice(p.price)} c/u)</span>
                </div>

                {p.short_description && (
                  <div class="pc-desc" set:html={p.short_description} />
                )}

                <!-- Qty + Agregar en una fila -->
                <div class="pc-cart-row">
                  <div class="pc-qty-wrap">
                    <button class="qty-btn qty-minus" aria-label="Restar">
                      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4"/></svg>
                    </button>
                    <input type="number" class="qty-input" value={multiplo} min={multiplo} step={multiplo} readonly />
                    <button class="qty-btn qty-plus" aria-label="Sumar">
                      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
                    </button>
                  </div>
                  <button class="pc-add-btn add-to-cart" aria-label="Agregar al carrito">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
                    Agregar
                  </button>
                </div>
              </div>
            </article>
            );
          })}
        </div>
      ) : (
        <div class="catalogo__empty" data-anim="fade-up">
          <svg width="64" height="64" fill="none" stroke="#cbd5e1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          <p>Estamos cargando el catálogo. ¡Pronto vas a poder ver todos nuestros productos!</p>
        </div>
      )}

      <div id="no-results" class="catalogo__empty hidden">
        <p>No hay productos en esta categoría.</p>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="cta">
    <div class="cta__bg">
      <img src="/images/hero-empresa.jpg" alt="Planta RecoPlas" loading="lazy" />
      <div class="cta__overlay"></div>
    </div>
    <div class="cta__container" data-anim="fade-up">
      <div class="cta__badge">
        <span class="cta__badge-dot"></span>
        ¿No encontrás lo que buscás?
      </div>
      <h2 class="cta__title">
        Fabricamos productos
        <span class="cta__title-accent">a tu medida</span>
      </h2>
      <p class="cta__text">
        Contactanos y te asesoramos. Medidas, espesores, colores e impresión personalizada.
      </p>
      <div class="cta__actions">
        <a href="/contacto" class="rp-btn rp-btn--green rp-btn--lg">
          Solicitar Cotización
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="https://wa.me/543482200375" target="_blank" rel="noopener" class="rp-btn rp-btn--white-ghost rp-btn--lg">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Consultanos
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <!-- CARRITO DRAWER -->
  <div id="cart-overlay" class="cart-overlay"></div>
  <aside id="cart-drawer" class="cart-drawer">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">
        <span class="cart-drawer__icon-wrap">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
          <span id="cart-header-badge" class="cart-drawer__badge hidden">0</span>
        </span>
        Tu carrito
      </h2>
      <button id="cart-close" class="cart-drawer__close" aria-label="Cerrar carrito">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="cart-items" class="cart-drawer__items"></div>
    <div id="cart-empty" class="cart-drawer__empty">
      <svg width="56" height="56" fill="none" stroke="#cbd5e1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
      <p>Tu carrito está vacío</p>
    </div>
    <div id="cart-footer" class="cart-drawer__footer">
      <div class="cart-drawer__subtotal">
        <span>Subtotal:</span>
        <strong id="cart-subtotal">$ 0</strong>
      </div>
      <a href="/carrito" class="cart-drawer__btn cart-drawer__btn--outline">Ver carrito</a>
      <button id="cart-continue" class="cart-drawer__btn cart-drawer__btn--green">Continuar comprando</button>
      <a href="/checkout" class="cart-drawer__btn cart-drawer__btn--dark" id="cart-checkout-btn">
        Ir a pagar - <span id="cart-checkout-total">$ 0</span>
      </a>
    </div>
  </aside>

  <!-- BOTÓN FLOTANTE CARRITO -->
  <button id="cart-fab" class="cart-fab" aria-label="Abrir carrito">
    <svg width="26" height="26" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
    <span id="cart-badge" class="cart-badge hidden">0</span>
  </button>

  <!-- FLY PARTICLE -->
  <div id="fly-particle" class="fly-particle"></div>

</Layout>

<style>
/* ====== VARIABLES ====== */
:root {
  --g: #00AA28; --gd: #008f22; --gl: #33cc52; --gp: #e8f9ed;
  --dk: #1a1a1a; --gr: #64748b; --gl-bg: #f8faf9;
  --border: #e5e7eb;
  --r: 16px; --rl: 24px;
  --ease: .45s cubic-bezier(.23,1,.32,1);
}

/* ====== HERO (nosotros style) ====== */
.hero {
  position: relative;
  min-height: 90vh;
  display: flex; align-items: center;
  overflow: hidden;
  padding-bottom: 5rem;
}
.hero__bg { position: absolute; inset: 0; }
.hero__gradient {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--dk) 0%, #1e293b 50%, rgba(0,170,40,.12) 100%);
}
.hero__orb {
  position: absolute; border-radius: 50%;
  filter: blur(80px); pointer-events: none;
}
.hero__orb--1 {
  top: -10%; left: -5%;
  width: 500px; height: 500px;
  background: var(--g); opacity: .06;
}
.hero__orb--2 {
  bottom: -15%; right: -5%;
  width: 600px; height: 600px;
  background: var(--g); opacity: .04;
}
.hero__container {
  position: relative; z-index: 2;
  max-width: 1280px; margin: 0 auto;
  padding: 0 2rem;
  display: grid; grid-template-columns: 1.4fr 1fr;
  gap: 3rem; align-items: center;
  width: 100%;
}
.hero__badge {
  display: inline-flex; align-items: center; gap: .5rem;
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(10px);
  padding: .5rem 1.2rem; border-radius: 999px;
  margin-bottom: 1.5rem;
  color: rgba(255,255,255,.85); font-size: .82rem; font-weight: 600;
  border: 1px solid rgba(255,255,255,.08);
}
.hero__badge-dot {
  width: 8px; height: 8px;
  background: var(--g); border-radius: 50%;
  animation: pulse-dot 2s ease-in-out infinite;
}
.hero__title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(2.2rem, 4.5vw, 3.5rem);
  font-weight: 800; line-height: 1.1;
  color: #fff; margin: 0 0 1.5rem;
}
.hero__title-accent {
  display: block;
  background: linear-gradient(135deg, var(--g) 0%, #00dd35 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero__text {
  color: rgba(255,255,255,.7); font-size: 1.05rem;
  line-height: 1.7; margin: 0 0 2rem; max-width: 520px;
}
.hero__actions { display: flex; flex-wrap: wrap; gap: 1rem; }

.hero__visual { display: none; position: relative; }
.hero__img-wrap {
  border-radius: var(--rl); overflow: hidden;
  box-shadow: 0 25px 60px rgba(0,0,0,.35);
}
.hero__img-wrap img {
  width: 100%; height: 420px; object-fit: cover; display: block;
}
.hero__floating-card {
  position: absolute; bottom: -20px; left: -20px;
  background: #fff; border-radius: 16px; padding: 1rem 1.25rem;
  display: flex; align-items: center; gap: .75rem;
  box-shadow: 0 12px 40px rgba(0,0,0,.15);
  animation: float-card 3s ease-in-out infinite;
}
.hero__floating-icon {
  width: 40px; height: 40px; border-radius: 12px;
  background: var(--gp);
  display: flex; align-items: center; justify-content: center;
}
.hero__floating-icon svg { width: 20px; height: 20px; color: var(--g); }
.hero__floating-title { font-weight: 700; font-size: .82rem; color: var(--dk); margin: 0; }
.hero__floating-sub { font-size: .72rem; color: var(--gr); margin: 0; }

.hero__wave {
  position: absolute; bottom: 0; left: 0; right: 0;
  z-index: 3; line-height: 0;
}
.hero__wave svg { width: 100%; height: auto; display: block; }

@media (min-width: 1024px) { .hero__visual { display: block; } }
@media (max-width: 1023px) {
  .hero__container { grid-template-columns: 1fr; }
  .hero__title { font-size: clamp(2.4rem, 8vw, 3rem); }
  .hero__content { text-align: center; }
  .hero__text { margin-left: auto; margin-right: auto; }
  .hero__actions { justify-content: center; }
  .hero__badge { margin-left: auto; margin-right: auto; }
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: .5; transform: scale(.85); }
}
@keyframes float-card {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

/* ====== BUTTONS (rp-btn) ====== */
.rp-btn {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .85rem 2rem; border-radius: 999px;
  font-weight: 700; font-size: .9rem;
  text-decoration: none; border: none; cursor: pointer;
  transition: all .3s ease;
  position: relative; overflow: hidden;
}
.rp-btn::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,.15) 100%);
  opacity: 0; transition: opacity .3s;
}
.rp-btn:hover::after { opacity: 1; }
.rp-btn--green {
  background: var(--g); color: #fff;
  box-shadow: 0 4px 20px rgba(0,170,40,.35);
}
.rp-btn--green:hover {
  background: var(--gd);
  box-shadow: 0 8px 30px rgba(0,170,40,.45);
  transform: translateY(-2px);
}
.rp-btn--white {
  background: #fff; color: var(--dk);
  box-shadow: 0 4px 20px rgba(0,0,0,.1);
}
.rp-btn--white:hover {
  box-shadow: 0 8px 30px rgba(0,0,0,.15);
  transform: translateY(-2px);
}
.rp-btn--ghost {
  background: rgba(255,255,255,.08); color: #fff;
  border: 1px solid rgba(255,255,255,.2);
}
.rp-btn--ghost:hover {
  background: rgba(255,255,255,.15);
  border-color: rgba(255,255,255,.4);
  transform: translateY(-2px);
}

/* ====== CATALOGO ====== */
.catalogo { padding: 2.5rem 0 5rem; }
.catalogo__container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

.catalogo__header { text-align: center; max-width: 700px; margin: 0 auto 2.5rem; }
.sec-label {
  display: inline-block; color: var(--g); font-weight: 700;
  text-transform: uppercase; letter-spacing: .12em; font-size: .8rem;
  margin-bottom: .75rem;
}
.sec-title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.75rem);
  font-weight: 800; color: var(--dk); line-height: 1.15;
  margin: 0 0 1rem;
}
.sec-desc { color: var(--gr); font-size: .95rem; line-height: 1.6; margin: 0; }

.catalogo__filters {
  display: flex; flex-wrap: wrap; justify-content: center;
  gap: .6rem; margin-bottom: 3rem;
}

.cat-btn {
  display: inline-flex; align-items: center; gap: .4rem;
  padding: .55rem 1.2rem; border-radius: 999px;
  font-size: .82rem; font-weight: 600;
  border: 2px solid var(--border); background: #fff; color: var(--gr);
  cursor: pointer; transition: all .25s ease;
}
.cat-btn:hover { border-color: var(--g); color: var(--g); }
.cat-btn.active { background: var(--g); border-color: var(--g); color: #fff; }

.catalogo__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.5rem;
}

.catalogo__empty {
  text-align: center; padding: 4rem 2rem;
  display: flex; flex-direction: column; align-items: center; gap: 1rem;
  color: var(--gr); font-size: 1rem;
}
.catalogo__empty.hidden { display: none; }

/* ====== PRODUCT CARD ====== */
.product-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  transition: box-shadow .3s ease, transform .3s ease;
  display: flex; flex-direction: column;
}
.product-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,.1); transform: translateY(-3px); }
.product-card.is-hidden { display: none; }

.pc-img-link { display: block; text-decoration: none; }

.pc-img {
  position: relative;
  background: linear-gradient(145deg, #f0f2f0 0%, #e8ebe8 100%);
  display: flex; align-items: center; justify-content: center;
  aspect-ratio: 1;
  overflow: hidden;
}
.pc-img img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform .4s ease;
  mix-blend-mode: multiply;
}
.product-card:hover .pc-img img { transform: scale(1.06); }

.pc-badge {
  position: absolute; top: 10px; left: 10px;
  background: var(--g); color: #fff;
  font-size: .65rem; font-weight: 700; letter-spacing: .04em;
  padding: .3rem .7rem; border-radius: 6px;
  box-shadow: 0 2px 8px rgba(0,170,40,.3);
  z-index: 2; text-transform: uppercase;
}

.pc-body {
  padding: 1rem 1.15rem 1.15rem;
  display: flex; flex-direction: column; flex: 1;
  border-top: 1px solid var(--border);
}

.pc-name-link { text-decoration: none; }
.pc-name {
  font-family: 'Montserrat', sans-serif;
  font-size: .95rem; font-weight: 700; color: var(--dk);
  line-height: 1.3; margin: 0 0 .5rem;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  transition: color .2s;
}
.pc-name-link:hover .pc-name { color: var(--g); }

.pc-price-row { display: flex; align-items: baseline; gap: .4rem; margin-bottom: .5rem; flex-wrap: wrap; }
.pc-price { font-size: 1.35rem; font-weight: 800; color: var(--g); font-family: 'Montserrat', sans-serif; }
.pc-price-unit { font-size: .7rem; color: var(--gr); font-weight: 500; }

.pc-desc {
  font-size: .72rem; color: var(--gr); line-height: 1.4;
  margin: 0 0 .65rem;
}
.pc-desc p { margin: 0; }

/* Qty + Add row */
.pc-cart-row {
  display: flex; align-items: center; gap: .5rem;
  margin-top: auto;
}

.pc-qty-wrap {
  display: flex; align-items: center;
  border: 1.5px solid var(--border); border-radius: 8px;
  overflow: hidden;
  transition: border-color .2s;
  flex-shrink: 0;
}
.pc-qty-wrap:focus-within { border-color: var(--g); }

.qty-btn {
  width: 30px; height: 32px; min-width: 30px;
  background: #f8f9fa; border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--gr); transition: all .2s;
}
.qty-btn:hover { background: var(--gp); color: var(--g); }

.qty-input {
  width: 36px; border: none; outline: none;
  text-align: center; font-size: .8rem; font-weight: 700;
  color: var(--dk); background: #fff;
  -moz-appearance: textfield;
}
.qty-input::-webkit-outer-spin-button,
.qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

/* Add button */
.pc-add-btn {
  display: flex; align-items: center; justify-content: center; gap: .4rem;
  flex: 1; padding: .55rem .75rem;
  background: var(--g); color: #fff;
  border: none; border-radius: 8px;
  font-size: .78rem; font-weight: 700;
  cursor: pointer; transition: background .25s, transform .2s, box-shadow .25s;
  white-space: nowrap;
}
.pc-add-btn:hover { background: var(--gd); box-shadow: 0 6px 20px rgba(0,170,40,.35); transform: translateY(-1px); }
.pc-add-btn.added { background: #16a34a; pointer-events: none; }

/* ====== CTA (home style) ====== */
.cta {
  position: relative;
  min-height: 70vh;
  display: flex; align-items: center;
  padding: 6rem 0;
  overflow: hidden;
}
.cta__bg { position: absolute; inset: 0; }
.cta__bg img { width: 100%; height: 100%; object-fit: cover; }
.cta__overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,.75);
}
.cta__container {
  position: relative; z-index: 2;
  width: 100%; max-width: 1280px; margin: 0 auto;
  padding: 0 2.5rem;
}
.cta__badge {
  display: inline-flex; align-items: center; gap: .5rem;
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(10px);
  padding: .5rem 1.2rem; border-radius: 999px;
  margin-bottom: 1.5rem;
  color: rgba(255,255,255,.85); font-size: .82rem; font-weight: 600;
  border: 1px solid rgba(255,255,255,.08);
}
.cta__badge-dot {
  width: 8px; height: 8px;
  background: var(--g); border-radius: 50%;
  animation: pulse-dot 2s ease-in-out infinite;
}
.cta__title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800; line-height: 1.15;
  color: #fff; margin: 0 0 1.25rem;
  max-width: 550px;
}
.cta__title-accent {
  display: block;
  background: linear-gradient(135deg, var(--g) 0%, #00dd35 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.cta__text {
  color: rgba(255,255,255,.65); font-size: 1.05rem;
  line-height: 1.8; margin: 0 0 2.5rem; max-width: 500px;
}
.cta__actions { display: flex; flex-wrap: wrap; gap: 1rem; }

.rp-btn--lg { padding: 1rem 2.5rem; font-size: .95rem; }

.rp-btn--white-ghost {
  background: rgba(255,255,255,.08); color: #fff;
  border: 2px solid rgba(255,255,255,.2);
  backdrop-filter: blur(8px);
}
.rp-btn--white-ghost:hover {
  background: rgba(255,255,255,.15);
  border-color: rgba(255,255,255,.35);
  transform: translateY(-2px);
}

@media (max-width: 640px) {
  .cta { min-height: 50vh; padding: 4rem 0; }
  .cta__container { padding: 0 1.5rem; }
  .cta__title { font-size: clamp(1.6rem, 7vw, 2.2rem); }
  .cta__actions { flex-direction: column; }
  .cta__actions .rp-btn { justify-content: center; }
}

/* ====== CART FAB ====== */
.cart-fab {
  position: fixed; bottom: 28px; right: 28px; z-index: 900;
  width: 60px; height: 60px; border-radius: 50%;
  background: var(--g); color: #fff; border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; box-shadow: 0 6px 24px rgba(0,170,40,.45);
  transition: transform .3s ease, box-shadow .3s ease;
}
.cart-fab:hover { transform: scale(1.1); box-shadow: 0 10px 32px rgba(0,170,40,.55); }

.cart-badge {
  position: absolute; top: -4px; right: -4px;
  width: 22px; height: 22px; border-radius: 50%;
  background: #ef4444; color: #fff;
  font-size: .7rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  border: 2px solid #fff;
  animation: badge-pop .3s ease;
}
.cart-badge.hidden { display: none; }
@keyframes badge-pop { 0%{transform:scale(0)} 70%{transform:scale(1.3)} 100%{transform:scale(1)} }

/* ====== CART DRAWER ====== */
.cart-overlay {
  position: fixed; inset: 0; z-index: 950;
  background: rgba(0,0,0,.45); backdrop-filter: blur(2px);
  opacity: 0; pointer-events: none; transition: opacity .35s ease;
}
.cart-overlay.open { opacity: 1; pointer-events: all; }

.cart-drawer {
  position: fixed; top: 0; right: 0; bottom: 0; z-index: 960;
  width: 420px; max-width: 100vw;
  background: #fff; box-shadow: -8px 0 40px rgba(0,0,0,.12);
  display: flex; flex-direction: column;
  transform: translateX(100%); transition: transform .4s cubic-bezier(.23,1,.32,1);
}
.cart-drawer.open { transform: translateX(0); }

.cart-drawer__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
}
.cart-drawer__title {
  display: flex; align-items: center; gap: .6rem;
  font-size: 1.15rem; font-weight: 800; color: var(--dk); margin: 0;
}
.cart-drawer__icon-wrap {
  position: relative;
  display: flex; align-items: center; justify-content: center;
}
.cart-drawer__badge {
  position: absolute; top: -8px; left: -8px;
  min-width: 18px; height: 18px; border-radius: 999px;
  padding: 0 4px;
  background: var(--g); color: #fff;
  font-size: .6rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
}
.cart-drawer__badge.hidden { display: none; }
.cart-drawer__close {
  width: 32px; height: 32px; border-radius: 6px; border: none;
  background: transparent; color: var(--dk);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: background .2s, color .2s;
  font-size: 1.2rem;
}
.cart-drawer__close:hover { background: #f1f5f9; color: var(--gr); }

.cart-drawer__items { flex: 1; overflow-y: auto; padding: .5rem 1.15rem; }

.cart-drawer__empty {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 1rem;
  color: var(--gr); font-size: .95rem;
}

.cart-drawer__footer {
  padding: 1.15rem 1.25rem;
  border-top: 1px solid var(--border);
  background: #fafbfc;
  display: flex; flex-direction: column; gap: .55rem;
}
.cart-drawer__subtotal {
  display: flex; justify-content: space-between; align-items: center;
  font-size: .92rem; color: var(--gr); font-weight: 600;
  padding-bottom: .5rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: .15rem;
}
.cart-drawer__subtotal strong {
  font-size: 1.2rem; font-weight: 800; color: var(--dk);
  font-family: 'Montserrat', sans-serif;
}
.cart-drawer__btn {
  display: flex; align-items: center; justify-content: center; gap: .5rem;
  padding: .75rem; border-radius: 12px;
  font-weight: 700; font-size: .88rem; text-decoration: none;
  cursor: pointer; border: none;
  transition: all .25s ease;
  font-family: inherit;
}
.cart-drawer__btn--outline {
  background: #fff; color: var(--g);
  border: 2px solid var(--g);
}
.cart-drawer__btn--outline:hover { background: var(--gp); transform: translateY(-1px); }
.cart-drawer__btn--green {
  background: var(--g); color: #fff;
  box-shadow: 0 2px 10px rgba(0,170,40,.2);
}
.cart-drawer__btn--green:hover { background: var(--gd); box-shadow: 0 6px 20px rgba(0,170,40,.35); transform: translateY(-1px); }
.cart-drawer__btn--dark {
  background: var(--dk); color: #fff;
  box-shadow: 0 2px 10px rgba(0,0,0,.1);
}
.cart-drawer__btn--dark:hover { background: #2d2d2d; box-shadow: 0 6px 20px rgba(0,0,0,.25); transform: translateY(-1px); }

/* ====== FLY PARTICLE ====== */
.fly-particle {
  position: fixed; z-index: 9999; pointer-events: none;
  width: 14px; height: 14px; border-radius: 50%;
  background: var(--g); opacity: 0;
}

/* ====== ANIMATIONS ====== */
[data-anim] {
  opacity: 0; transform: translateY(30px);
  transition: opacity var(--ease), transform var(--ease);
}
[data-anim="fade-left"] { transform: translateX(40px); }
[data-anim="fade-right"] { transform: translateX(-40px); }
[data-anim].is-visible { opacity: 1; transform: none; }
</style>

<style is:global>
/* Cart items (generados dinámicamente por JS) */
.cart-item {
  display: flex; gap: .85rem; align-items: center;
  padding: .7rem .75rem;
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  margin-bottom: .55rem;
  box-shadow: 0 1px 4px rgba(0,0,0,.05);
  transition: box-shadow .2s;
}
.cart-item:hover { box-shadow: 0 3px 12px rgba(0,0,0,.08); }
.cart-item__img {
  width: 82px; height: 82px; border-radius: 10px;
  background: linear-gradient(145deg, #f5f6f5 0%, #eaeceb 100%);
  overflow: hidden; flex-shrink: 0;
  padding: 5px;
}
.cart-item__img img {
  width: 100%; height: 100%; object-fit: cover;
  border-radius: 7px; mix-blend-mode: multiply;
}
.cart-item__info { flex: 1; min-width: 0; }
.cart-item__name {
  font-size: .88rem; font-weight: 700; color: #1a1a1a; margin: 0 0 .2rem;
  line-height: 1.3;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.cart-item__price {
  font-size: .88rem; font-weight: 800; color: #00AA28;
  margin: 0 0 .4rem;
}
.cart-item__bottom {
  display: flex; align-items: center; justify-content: space-between;
}
.cart-item__qty-ctrl {
  display: inline-flex; align-items: center;
  border: 1px solid #e5e7eb; border-radius: 8px;
  overflow: hidden;
}
.cart-item__qty-btn {
  width: 28px; height: 26px;
  background: #f8f9fa; border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: #1a1a1a; font-size: .82rem;
  transition: background .15s, color .15s;
}
.cart-item__qty-btn:hover { background: #e8f9ed; color: #00AA28; }
.cart-item__qty-val {
  width: 30px; height: 26px;
  display: flex; align-items: center; justify-content: center;
  font-size: .78rem; font-weight: 700; color: #1a1a1a;
  border-left: 1px solid #e5e7eb;
  border-right: 1px solid #e5e7eb;
  background: #fff;
}
.cart-item__remove {
  width: 28px; height: 28px; min-width: 28px;
  border-radius: 7px; border: none;
  background: transparent;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: #ef4444;
  transition: background .2s, color .2s;
  flex-shrink: 0;
}
.cart-item__remove:hover { background: #fee2e2; color: #dc2626; }
</style>

<script>
// ===== ANIMATIONS =====
const observer = new IntersectionObserver(
  (entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const delay = parseInt(el.dataset.delay || '0');
        setTimeout(() => el.classList.add('is-visible'), delay);
        observer.unobserve(el);
      }
    });
  },
  { threshold: 0.1 }
);
document.querySelectorAll('[data-anim]').forEach((el) => observer.observe(el));

// ===== TIPOS =====
interface CartItem {
  id: string;
  nombre: string;
  precio: number;
  cantidad: number;
  imagen: string;
}

// ===== UTILIDADES =====
function formatARS(n: number): string {
  return '$ ' + n.toLocaleString('es-AR');
}
function saveCart(cart: CartItem[]): void {
  localStorage.setItem('rp-cart', JSON.stringify(cart));
  document.dispatchEvent(new Event('cart-updated'));
}
function loadCart(): CartItem[] {
  try { return JSON.parse(localStorage.getItem('rp-cart') || '[]'); }
  catch { return []; }
}

// ===== CARRITO STATE =====
let cart: CartItem[] = loadCart();

// ===== RENDER CART =====
function renderCart(): void {
  const itemsEl  = document.getElementById('cart-items')!;
  const emptyEl  = document.getElementById('cart-empty')!;
  const footerEl = document.getElementById('cart-footer')!;
  const subtotalEl = document.getElementById('cart-subtotal')!;
  const badge = document.getElementById('cart-badge')!;

  const totalUnits = cart.reduce((s, i) => s + i.cantidad, 0);
  badge.textContent = String(totalUnits);
  badge.classList.toggle('hidden', totalUnits === 0);

  if (cart.length === 0) {
    itemsEl.innerHTML = '';
    emptyEl.style.display = 'flex';
    footerEl.style.display = 'none';
    return;
  }

  emptyEl.style.display = 'none';
  footerEl.style.display = 'flex';

  itemsEl.innerHTML = cart.map(item => {
    const imgFull = item.imagen.replace(/-\d+x\d+(\.\w+)$/, '$1');
    return `
    <div class="cart-item" data-id="${item.id}">
      <div class="cart-item__img">
        <img src="${imgFull}" alt="${item.nombre}" />
      </div>
      <div class="cart-item__info">
        <p class="cart-item__name">${item.nombre}</p>
        <p class="cart-item__price">${formatARS(item.precio * item.cantidad)}</p>
        <div class="cart-item__bottom">
          <div class="cart-item__qty-ctrl">
            <button class="cart-item__qty-btn" data-qty-minus="${item.id}">−</button>
            <span class="cart-item__qty-val">${item.cantidad}</span>
            <button class="cart-item__qty-btn" data-qty-plus="${item.id}">+</button>
          </div>
          <button class="cart-item__remove" data-remove="${item.id}" aria-label="Eliminar">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  `}).join('');

  itemsEl.querySelectorAll('[data-remove]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.remove!;
      cart = cart.filter(i => i.id !== id);
      saveCart(cart); renderCart();
    });
  });

  itemsEl.querySelectorAll('[data-qty-minus]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.qtyMinus!;
      const item = cart.find(i => i.id === id);
      if (item && item.cantidad > 1) { item.cantidad--; saveCart(cart); renderCart(); }
    });
  });

  itemsEl.querySelectorAll('[data-qty-plus]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.qtyPlus!;
      const item = cart.find(i => i.id === id);
      if (item) { item.cantidad++; saveCart(cart); renderCart(); }
    });
  });

  const subtotal = cart.reduce((s, i) => s + i.precio * i.cantidad, 0);
  subtotalEl.textContent = formatARS(subtotal);

  // Update checkout button total
  const checkoutTotal = document.getElementById('cart-checkout-total');
  if (checkoutTotal) checkoutTotal.textContent = formatARS(subtotal);

  // Update header badge inside drawer
  const headerBadge = document.getElementById('cart-header-badge');
  if (headerBadge) {
    headerBadge.textContent = String(totalUnits);
    headerBadge.classList.toggle('hidden', totalUnits === 0);
  }
}

// ===== OPEN / CLOSE DRAWER =====
function openCart(): void {
  document.getElementById('cart-drawer')!.classList.add('open');
  document.getElementById('cart-overlay')!.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeCart(): void {
  document.getElementById('cart-drawer')!.classList.remove('open');
  document.getElementById('cart-overlay')!.classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('cart-fab')!.addEventListener('click', openCart);
document.getElementById('cart-close')!.addEventListener('click', closeCart);
document.getElementById('cart-overlay')!.addEventListener('click', closeCart);
document.getElementById('cart-continue')!.addEventListener('click', closeCart);

// ===== FLY TO CART =====
function flyToCart(originEl: HTMLElement): void {
  const particle = document.getElementById('fly-particle')!;
  const fab = document.getElementById('cart-fab')!;
  const origin = originEl.getBoundingClientRect();
  const target = fab.getBoundingClientRect();

  const startX = origin.left + origin.width / 2 - 7;
  const startY = origin.top  + origin.height / 2 - 7;
  const endX   = target.left + target.width  / 2 - 7;
  const endY   = target.top  + target.height / 2 - 7;

  particle.style.cssText = `left:${startX}px; top:${startY}px; opacity:1;`;
  void particle.offsetWidth;

  particle.style.transition = `left .6s cubic-bezier(.23,1,.32,1), top .6s cubic-bezier(.23,1,.32,1), opacity .6s ease, transform .6s ease`;
  particle.style.left = endX + 'px';
  particle.style.top  = endY + 'px';
  particle.style.opacity = '0';
  particle.style.transform = 'scale(0)';

  setTimeout(() => { particle.style.cssText = ''; }, 700);
}

// ===== PRODUCT CARDS =====
document.querySelectorAll('.product-card').forEach(card => {
  const el      = card as HTMLElement;
  const id      = el.dataset.id!;
  const nombre  = el.dataset.nombre!;
  const precio  = Number(el.dataset.precio);
  const imagen  = el.dataset.imagen!;
  const multiplo = Number(el.dataset.multiplo) || 1;

  const input    = el.querySelector('.qty-input') as HTMLInputElement;
  const minusBtn = el.querySelector('.qty-minus') as HTMLButtonElement;
  const plusBtn  = el.querySelector('.qty-plus') as HTMLButtonElement;
  const addBtn   = el.querySelector('.pc-add-btn') as HTMLButtonElement;
  const priceEl  = el.querySelector('.pc-price') as HTMLElement;
  const unitPrice = Number(priceEl.dataset.unitPrice);

  function updatePrice() {
    const qty = Number(input.value);
    priceEl.textContent = formatARS(unitPrice * qty);
  }

  minusBtn.addEventListener('click', () => {
    const current = Number(input.value);
    if (current > multiplo) { input.value = String(current - multiplo); updatePrice(); }
  });

  plusBtn.addEventListener('click', () => {
    input.value = String(Number(input.value) + multiplo);
    updatePrice();
  });

  addBtn.addEventListener('click', () => {
    const cantidad = Number(input.value);
    const existing = cart.find(i => i.id === id);
    if (existing) { existing.cantidad += cantidad; }
    else { cart.push({ id, nombre, precio, cantidad, imagen }); }
    saveCart(cart);
    renderCart();
    flyToCart(addBtn);
    setTimeout(() => openCart(), 500);

    addBtn.textContent = '✓ Listo';
    addBtn.classList.add('added');
    setTimeout(() => {
      addBtn.innerHTML = `<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg> Agregar`;
      addBtn.classList.remove('added');
    }, 1800);
  });
});

// ===== CATEGORY FILTER =====
function filterByCategory(cat: string) {
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
  const activeBtn = document.querySelector(`.cat-btn[data-cat="${cat}"]`);
  if (activeBtn) activeBtn.classList.add('active');

  let count = 0;
  document.querySelectorAll('.product-card').forEach(card => {
    const cardCats = (card as HTMLElement).dataset.categoria || '';
    if (cat === 'todos' || cardCats.split(',').includes(cat)) {
      (card as HTMLElement).classList.remove('is-hidden'); count++;
    } else {
      (card as HTMLElement).classList.add('is-hidden');
    }
  });

  const noResults = document.getElementById('no-results')!;
  noResults.classList.toggle('hidden', count > 0);
}

document.querySelectorAll('.cat-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    filterByCategory((btn as HTMLElement).dataset.cat!);
  });
});

// Auto-filter from URL query param
const urlParams = new URLSearchParams(window.location.search);
const urlCat = urlParams.get('cat');
if (urlCat) filterByCategory(urlCat);

// ===== SEARCH =====
const urlSearch = urlParams.get('buscar');
if (urlSearch) {
  const query = urlSearch.toLowerCase();
  let count = 0;
  document.querySelectorAll('.product-card').forEach(card => {
    const el = card as HTMLElement;
    const nombre = (el.dataset.nombre || '').toLowerCase();
    if (nombre.includes(query)) {
      el.classList.remove('is-hidden'); count++;
    } else {
      el.classList.add('is-hidden');
    }
  });
  // Deselect category filters
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
  const noResults = document.getElementById('no-results')!;
  noResults.classList.toggle('hidden', count > 0);
}

// ===== INIT =====
renderCart();
</script>
