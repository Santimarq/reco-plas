---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProductos, getProductoBySlug, formatPrice } from '../../lib/wordpress';
import type { Producto } from '../../lib/wordpress';

const { slug } = Astro.params;
const producto = await getProductoBySlug(slug!);

if (!producto) {
  return Astro.redirect('/productos');
}

const allProductos = await getProductos();
const related = allProductos
  .filter(p => p.id !== producto.id && p.categories.some(c => producto.categories.some(pc => pc.id === c.id)))
  .slice(0, 4);

const mainImage = producto.images[0]?.src || '/images/producto-1.webp';
const gallery = producto.images.length > 1 ? producto.images : [];
const category = producto.categories.find(c => c.slug !== 'sin-categorizar');
const multiploAttr = producto.attributes.find(a => a.name.toLowerCase() === 'multiplo');
const shortText = producto.short_description?.replace(/<[^>]*>/g, '') || '';
const multiploMatch = shortText.match(/mínima:\s*([\d.]+)/i);
const multiplo = multiploAttr ? parseFloat(multiploAttr.options[0]) : (multiploMatch ? parseFloat(multiploMatch[1]) : 1);
---

<Layout title={`${producto.name} | Reco-Plas`} description={producto.short_description?.replace(/<[^>]*>/g, '') || `Comprá ${producto.name} directo de fábrica. Envíos a todo el país.`}>
  <Header />

  <!-- ========== BREADCRUMBS ========== -->
  <nav class="breadcrumbs" data-anim="fade-up">
    <div class="breadcrumbs__container">
      <a href="/">Inicio</a>
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      <a href="/productos">Productos</a>
      {category && (
        <>
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          <span class="breadcrumbs__cat">{category.name}</span>
        </>
      )}
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      <span class="breadcrumbs__current">{producto.name}</span>
    </div>
  </nav>

  <!-- ========== PRODUCTO ========== -->
  <section class="product">
    <div class="product__container">

      <!-- Galería -->
      <div class="product__gallery" data-anim="fade-up">
        <div class="product__main-img" id="main-img-wrap">
          <img id="main-img" src={mainImage} alt={producto.name} />
        </div>
        {gallery.length > 1 && (
          <div class="product__thumbs">
            {gallery.map((img, i) => (
              <button
                class={`product__thumb ${i === 0 ? 'active' : ''}`}
                data-src={img.src}
              >
                <img src={img.src} alt={img.alt || `${producto.name} ${i + 1}`} loading="lazy" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div class="product__info" data-anim="fade-up" data-delay="100">
        {category && (
          <span class="product__category">{category.name}</span>
        )}

        <h1 class="product__name">{producto.name}</h1>

        <div class="product__price-block">
          <span class="product__price" id="product-price" data-unit-price={producto.price}>{formatPrice(Number(producto.price) * multiplo)}</span>
          <span class="product__price-unit">({formatPrice(producto.price)} c/u)</span>
          {producto.sale_price && producto.regular_price && producto.sale_price !== producto.regular_price && (
            <span class="product__price-old">{formatPrice(producto.regular_price)}</span>
          )}
        </div>

        <div class="product__stock">
          <span class={`stock-dot ${producto.stock_status === 'instock' ? 'in' : 'out'}`}></span>
          {producto.stock_status === 'instock' ? 'En stock' : 'Sin stock'}
        </div>

        {producto.short_description && (
          <div class="product__short-desc" set:html={producto.short_description} />
        )}

        <!-- Atributos -->
        {producto.attributes.length > 0 && (
          <div class="product__attrs">
            {producto.attributes.map(attr => (
              <div class="product__attr">
                <span class="product__attr-label">{attr.name}</span>
                <span class="product__attr-value">{attr.options.join(', ')}</span>
              </div>
            ))}
          </div>
        )}

        <div class="product__divider"></div>

        <!-- Cantidad + Agregar -->
        <div class="product__actions"
          data-id={producto.id}
          data-nombre={producto.name}
          data-precio={producto.price}
          data-imagen={mainImage}
          data-multiplo={multiplo}
        >
          <div class="product__qty-wrap">
            <button class="product__qty-btn" id="qty-minus" aria-label="Restar">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4"/></svg>
            </button>
            <input type="number" class="product__qty-input" id="qty-input" value={multiplo} min={multiplo} step={multiplo} readonly />
            <button class="product__qty-btn" id="qty-plus" aria-label="Sumar">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
            </button>
          </div>

          <button class="product__add-btn" id="add-to-cart">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
            Agregar al carrito
          </button>
        </div>

        <!-- WhatsApp -->
        <a href={`https://wa.me/543482312021?text=Hola! Me interesa el producto: ${encodeURIComponent(producto.name)}`} target="_blank" rel="noopener" class="product__whatsapp">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Consultar por WhatsApp
        </a>

        <!-- Garantías -->
        <div class="product__guarantees">
          <div class="product__guarantee">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Fabricación propia</span>
          </div>
          <div class="product__guarantee">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
            <span>Envíos a todo el país</span>
          </div>
          <div class="product__guarantee">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <span>Calidad garantizada</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== DESCRIPCIÓN ========== -->
  {producto.description && (
    <section class="desc-section">
      <div class="desc-section__container" data-anim="fade-up">
        <h2 class="desc-section__title">Descripción del producto</h2>
        <div class="desc-section__content" set:html={producto.description} />
      </div>
    </section>
  )}

  <!-- ========== RELACIONADOS ========== -->
  {related.length > 0 && (
    <section class="related">
      <div class="related__container">
        <div class="related__header" data-anim="fade-up">
          <span class="sec-label">También te puede interesar</span>
          <h2 class="sec-title">Productos relacionados</h2>
        </div>
        <div class="related__grid">
          {related.map((p) => (
            <a href={`/productos/${p.slug}`} class="related-card" data-anim="fade-up">
              <div class="related-card__img">
                <img src={p.images[0]?.src || '/images/producto-1.webp'} alt={p.name} loading="lazy" />
              </div>
              <div class="related-card__body">
                <h3 class="related-card__name">{p.name}</h3>
                <span class="related-card__price">{formatPrice(p.price)}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ========== CTA ========== -->
  <section class="cta">
    <div class="cta__bg">
      <img src="/images/hero-empresa.jpg" alt="Planta RecoPlas" loading="lazy" />
      <div class="cta__overlay"></div>
    </div>
    <div class="cta__container" data-anim="fade-up">
      <div class="cta__badge">
        <span class="cta__badge-dot"></span>
        ¿Necesitás una medida especial?
      </div>
      <h2 class="cta__title">
        Fabricamos productos
        <span class="cta__title-accent">a tu medida</span>
      </h2>
      <p class="cta__text">
        Contactanos y te asesoramos. Medidas, espesores, colores e impresión personalizada.
      </p>
      <div class="cta__actions">
        <a href="/contacto" class="rp-btn rp-btn--green rp-btn--lg">
          Solicitar Cotización
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="https://wa.me/543482312021" target="_blank" rel="noopener" class="rp-btn rp-btn--white-ghost rp-btn--lg">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Consultanos
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <!-- CARRITO DRAWER -->
  <div id="cart-overlay" class="cart-overlay"></div>
  <aside id="cart-drawer" class="cart-drawer">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">
        <span class="cart-drawer__icon-wrap">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
          <span id="cart-header-badge" class="cart-drawer__badge hidden">0</span>
        </span>
        Tu carrito
      </h2>
      <button id="cart-close" class="cart-drawer__close" aria-label="Cerrar carrito">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="cart-items" class="cart-drawer__items"></div>
    <div id="cart-empty" class="cart-drawer__empty">
      <svg width="56" height="56" fill="none" stroke="#cbd5e1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
      <p>Tu carrito está vacío</p>
    </div>
    <div id="cart-footer" class="cart-drawer__footer">
      <div class="cart-drawer__subtotal">
        <span>Subtotal:</span>
        <strong id="cart-subtotal">$ 0</strong>
      </div>
      <a href="/carrito" class="cart-drawer__btn cart-drawer__btn--outline">Ver carrito</a>
      <button id="cart-continue" class="cart-drawer__btn cart-drawer__btn--green">Continuar comprando</button>
      <a href="/checkout" class="cart-drawer__btn cart-drawer__btn--dark" id="cart-checkout-btn">
        Ir a pagar - <span id="cart-checkout-total">$ 0</span>
      </a>
    </div>
  </aside>

  <!-- BOTÓN FLOTANTE CARRITO -->
  <button id="cart-fab" class="cart-fab" aria-label="Abrir carrito">
    <svg width="26" height="26" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
    <span id="cart-badge" class="cart-badge hidden">0</span>
  </button>

  <div id="fly-particle" class="fly-particle"></div>
</Layout>

<style>
/* ====== VARIABLES ====== */
:root {
  --g: #00AA28; --gd: #008f22; --gl: #33cc52; --gp: #e8f9ed;
  --dk: #1a1a1a; --gr: #64748b; --gl-bg: #f8faf9;
  --border: #e5e7eb;
  --r: 16px; --rl: 24px;
  --ease: .45s cubic-bezier(.23,1,.32,1);
}

/* ====== BREADCRUMBS ====== */
.breadcrumbs {
  background: #f8faf9;
  border-bottom: 1px solid var(--border);
}
.breadcrumbs__container {
  max-width: 1280px; margin: 0 auto;
  padding: .85rem 2rem;
  display: flex; align-items: center; gap: .5rem;
  flex-wrap: wrap;
  font-size: .82rem;
}
.breadcrumbs__container a {
  color: var(--gr); text-decoration: none;
  transition: color .2s;
}
.breadcrumbs__container a:hover { color: var(--g); }
.breadcrumbs__container svg { color: #cbd5e1; flex-shrink: 0; }
.breadcrumbs__cat { color: var(--gr); }
.breadcrumbs__current {
  color: var(--dk); font-weight: 600;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 300px;
}

/* ====== PRODUCT SECTION ====== */
.product { padding: 3rem 0 4rem; }
.product__container {
  max-width: 1280px; margin: 0 auto;
  padding: 0 2rem;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 3.5rem; align-items: flex-start;
}

/* Gallery */
.product__gallery { position: sticky; top: 100px; }
.product__main-img {
  background: linear-gradient(145deg, #f0f2f0 0%, #e8ebe8 100%);
  border-radius: 20px;
  overflow: hidden;
  aspect-ratio: 1;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--border);
}
.product__main-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  mix-blend-mode: multiply;
  transition: transform .4s ease;
}
.product__main-img:hover img { transform: scale(1.05); }

.product__thumbs {
  display: flex; gap: .6rem;
  margin-top: .8rem;
  overflow-x: auto;
  padding-bottom: .25rem;
}
.product__thumb {
  width: 72px; height: 72px; flex-shrink: 0;
  border-radius: 12px;
  border: 2px solid var(--border);
  background: linear-gradient(145deg, #f0f2f0 0%, #e8ebe8 100%);
  overflow: hidden;
  cursor: pointer;
  transition: border-color .2s, box-shadow .2s;
  padding: 0;
}
.product__thumb img {
  width: 100%; height: 100%;
  object-fit: cover;
  mix-blend-mode: multiply;
}
.product__thumb:hover { border-color: var(--g); }
.product__thumb.active {
  border-color: var(--g);
  box-shadow: 0 0 0 3px rgba(0,170,40,.15);
}

/* Info */
.product__category {
  display: inline-block;
  background: var(--gp); color: var(--g);
  font-size: .75rem; font-weight: 700;
  padding: .3rem .8rem; border-radius: 8px;
  margin-bottom: 1rem;
  text-transform: uppercase; letter-spacing: .04em;
}

.product__name {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 800; color: var(--dk);
  line-height: 1.2; margin: 0 0 1.25rem;
}

.product__price-block {
  display: flex; align-items: baseline; gap: .75rem;
  margin-bottom: .75rem;
}
.product__price {
  font-size: 2rem; font-weight: 800; color: var(--g);
  font-family: 'Montserrat', sans-serif;
}
.product__price-unit {
  font-size: .85rem; color: var(--gr); font-weight: 500;
}
.product__price-old {
  font-size: 1.1rem; color: #94a3b8;
  text-decoration: line-through;
}

.product__stock {
  display: inline-flex; align-items: center; gap: .45rem;
  font-size: .82rem; font-weight: 600;
  margin-bottom: 1.25rem;
  color: var(--gr);
}
.stock-dot {
  width: 8px; height: 8px; border-radius: 50%;
}
.stock-dot.in {
  background: var(--g);
  box-shadow: 0 0 0 3px rgba(0,170,40,.2);
}
.stock-dot.out {
  background: #ef4444;
  box-shadow: 0 0 0 3px rgba(239,68,68,.2);
}

.product__short-desc {
  color: var(--gr); font-size: .92rem; line-height: 1.7;
  margin-bottom: 1.25rem;
}
.product__short-desc p { margin: 0; }

/* Atributos */
.product__attrs {
  display: flex; flex-direction: column; gap: .5rem;
  margin-bottom: 1.25rem;
}
.product__attr {
  display: flex; align-items: center; gap: .5rem;
  font-size: .85rem;
}
.product__attr-label {
  font-weight: 700; color: var(--dk);
  min-width: 100px;
}
.product__attr-value { color: var(--gr); }

.product__divider {
  height: 1px; background: var(--border);
  margin: .5rem 0 1.5rem;
}

/* Actions */
.product__actions {
  display: flex; gap: .75rem;
  margin-bottom: 1rem;
}
.product__qty-wrap {
  display: flex; align-items: center;
  border: 2px solid var(--border); border-radius: 12px;
  overflow: hidden;
  transition: border-color .2s;
}
.product__qty-wrap:focus-within { border-color: var(--g); }

.product__qty-btn {
  width: 44px; height: 48px;
  background: #f8f9fa; border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--gr); transition: all .2s;
}
.product__qty-btn:hover { background: var(--gp); color: var(--g); }

.product__qty-input {
  width: 48px; border: none; outline: none;
  text-align: center; font-size: 1rem; font-weight: 700;
  color: var(--dk); background: #fff;
  -moz-appearance: textfield;
}
.product__qty-input::-webkit-outer-spin-button,
.product__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

.product__add-btn {
  flex: 1;
  display: flex; align-items: center; justify-content: center; gap: .5rem;
  background: var(--g); color: #fff;
  border: none; border-radius: 12px;
  font-size: .95rem; font-weight: 700;
  cursor: pointer;
  transition: background .25s, transform .2s, box-shadow .25s;
}
.product__add-btn:hover {
  background: var(--gd);
  box-shadow: 0 8px 24px rgba(0,170,40,.35);
  transform: translateY(-1px);
}
.product__add-btn.added { background: #16a34a; pointer-events: none; }

/* WhatsApp */
.product__whatsapp {
  display: flex; align-items: center; justify-content: center; gap: .5rem;
  width: 100%; padding: .85rem;
  background: #fff; color: #25D366;
  border: 2px solid #25D366; border-radius: 12px;
  font-size: .9rem; font-weight: 700;
  text-decoration: none;
  transition: background .25s, color .2s;
  margin-bottom: 1.5rem;
}
.product__whatsapp:hover { background: #25D366; color: #fff; }

/* Guarantees */
.product__guarantees {
  display: flex; flex-direction: column; gap: .65rem;
  padding: 1.25rem;
  background: var(--gl-bg);
  border-radius: 14px;
  border: 1px solid var(--border);
}
.product__guarantee {
  display: flex; align-items: center; gap: .6rem;
  font-size: .82rem; font-weight: 600; color: var(--dk);
}
.product__guarantee svg { color: var(--g); flex-shrink: 0; }

/* ====== DESCRIPTION ====== */
.desc-section {
  padding: 3rem 0 4rem;
  background: var(--gl-bg);
  border-top: 1px solid var(--border);
}
.desc-section__container {
  max-width: 1280px; margin: 0 auto;
  padding: 0 2rem;
}
.desc-section__title {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.4rem; font-weight: 800; color: var(--dk);
  margin: 0 0 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 2px solid var(--g);
  display: inline-block;
}
.desc-section__content {
  color: #374151; font-size: .95rem; line-height: 1.8;
  max-width: 800px;
}
.desc-section__content p { margin: 0 0 1rem; }
.desc-section__content ul { padding-left: 1.25rem; margin: 0 0 1rem; }
.desc-section__content li { margin-bottom: .5rem; }

/* ====== RELATED ====== */
.related { padding: 4rem 0; }
.related__container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
.related__header { text-align: center; margin-bottom: 2.5rem; }

.sec-label {
  display: inline-block; color: var(--g); font-weight: 700;
  text-transform: uppercase; letter-spacing: .12em; font-size: .8rem;
  margin-bottom: .75rem;
}
.sec-title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.5rem);
  font-weight: 800; color: var(--dk); line-height: 1.15;
  margin: 0;
}

.related__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.25rem;
}

.related-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  text-decoration: none;
  transition: box-shadow .3s ease, transform .3s ease;
}
.related-card:hover {
  box-shadow: 0 12px 40px rgba(0,0,0,.1);
  transform: translateY(-3px);
}
.related-card__img {
  height: 180px;
  background: linear-gradient(145deg, #f0f2f0 0%, #e8ebe8 100%);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.related-card__img img {
  width: 100%; height: 100%;
  object-fit: cover;
  mix-blend-mode: multiply;
  transition: transform .4s ease;
}
.related-card:hover .related-card__img img { transform: scale(1.06); }

.related-card__body {
  padding: 1rem 1.15rem 1.15rem;
  border-top: 1px solid var(--border);
}
.related-card__name {
  font-size: .85rem; font-weight: 700; color: var(--dk);
  line-height: 1.35; margin: 0 0 .4rem;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.related-card__price {
  font-size: 1.15rem; font-weight: 800; color: var(--g);
}

/* ====== CTA (home style) ====== */
.cta {
  position: relative;
  min-height: 70vh;
  display: flex; align-items: center;
  padding: 6rem 0;
  overflow: hidden;
}
.cta__bg { position: absolute; inset: 0; }
.cta__bg img { width: 100%; height: 100%; object-fit: cover; }
.cta__overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,.75);
}
.cta__container {
  position: relative; z-index: 2;
  width: 100%; max-width: 1280px; margin: 0 auto;
  padding: 0 2.5rem;
}
.cta__badge {
  display: inline-flex; align-items: center; gap: .5rem;
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(10px);
  padding: .5rem 1.2rem; border-radius: 999px;
  margin-bottom: 1.5rem;
  color: rgba(255,255,255,.85); font-size: .82rem; font-weight: 600;
  border: 1px solid rgba(255,255,255,.08);
}
.cta__badge-dot {
  width: 8px; height: 8px;
  background: var(--g); border-radius: 50%;
  animation: pulse-dot 2s ease-in-out infinite;
}
.cta__title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800; line-height: 1.15;
  color: #fff; margin: 0 0 1.25rem;
  max-width: 550px;
}
.cta__title-accent {
  display: block;
  background: linear-gradient(135deg, var(--g) 0%, #00dd35 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.cta__text {
  color: rgba(255,255,255,.65); font-size: 1.05rem;
  line-height: 1.8; margin: 0 0 2.5rem; max-width: 500px;
}
.cta__actions { display: flex; flex-wrap: wrap; gap: 1rem; }

.rp-btn--lg { padding: 1rem 2.5rem; font-size: .95rem; }

.rp-btn--white-ghost {
  background: rgba(255,255,255,.08); color: #fff;
  border: 2px solid rgba(255,255,255,.2);
  backdrop-filter: blur(8px);
}
.rp-btn--white-ghost:hover {
  background: rgba(255,255,255,.15);
  border-color: rgba(255,255,255,.35);
  transform: translateY(-2px);
}

/* ====== BUTTONS ====== */
.rp-btn {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .85rem 2rem; border-radius: 999px;
  font-weight: 700; font-size: .9rem;
  text-decoration: none; border: none; cursor: pointer;
  transition: all .3s ease;
  position: relative; overflow: hidden;
}
.rp-btn::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,.15) 100%);
  opacity: 0; transition: opacity .3s;
}
.rp-btn:hover::after { opacity: 1; }
.rp-btn--green {
  background: var(--g); color: #fff;
  box-shadow: 0 4px 20px rgba(0,170,40,.35);
}
.rp-btn--green:hover {
  background: var(--gd);
  box-shadow: 0 8px 30px rgba(0,170,40,.45);
  transform: translateY(-2px);
}
.rp-btn--white {
  background: #fff; color: var(--dk);
  box-shadow: 0 4px 20px rgba(0,0,0,.1);
}
.rp-btn--white:hover {
  box-shadow: 0 8px 30px rgba(0,0,0,.15);
  transform: translateY(-2px);
}

/* ====== CART (same as index) ====== */
.cart-fab {
  position: fixed; bottom: 28px; right: 28px; z-index: 900;
  width: 60px; height: 60px; border-radius: 50%;
  background: var(--g); color: #fff; border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; box-shadow: 0 6px 24px rgba(0,170,40,.45);
  transition: transform .3s ease, box-shadow .3s ease;
}
.cart-fab:hover { transform: scale(1.1); box-shadow: 0 10px 32px rgba(0,170,40,.55); }

.cart-badge {
  position: absolute; top: -4px; right: -4px;
  width: 22px; height: 22px; border-radius: 50%;
  background: #ef4444; color: #fff;
  font-size: .7rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  border: 2px solid #fff;
}
.cart-badge.hidden { display: none; }

.cart-overlay {
  position: fixed; inset: 0; z-index: 950;
  background: rgba(0,0,0,.45); backdrop-filter: blur(2px);
  opacity: 0; pointer-events: none; transition: opacity .35s ease;
}
.cart-overlay.open { opacity: 1; pointer-events: all; }

.cart-drawer {
  position: fixed; top: 0; right: 0; bottom: 0; z-index: 960;
  width: 420px; max-width: 100vw;
  background: #fff; box-shadow: -8px 0 40px rgba(0,0,0,.12);
  display: flex; flex-direction: column;
  transform: translateX(100%); transition: transform .4s cubic-bezier(.23,1,.32,1);
}
.cart-drawer.open { transform: translateX(0); }

.cart-drawer__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
}
.cart-drawer__title {
  display: flex; align-items: center; gap: .6rem;
  font-size: 1.15rem; font-weight: 800; color: var(--dk); margin: 0;
}
.cart-drawer__icon-wrap {
  position: relative;
  display: flex; align-items: center; justify-content: center;
}
.cart-drawer__badge {
  position: absolute; top: -8px; left: -8px;
  min-width: 18px; height: 18px; border-radius: 999px;
  padding: 0 4px;
  background: var(--g); color: #fff;
  font-size: .6rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
}
.cart-drawer__badge.hidden { display: none; }
.cart-drawer__close {
  width: 32px; height: 32px; border-radius: 6px; border: none;
  background: transparent; color: var(--dk);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: background .2s, color .2s;
  font-size: 1.2rem;
}
.cart-drawer__close:hover { background: #f1f5f9; color: var(--gr); }

.cart-drawer__items { flex: 1; overflow-y: auto; padding: .5rem 1.15rem; }

.cart-drawer__empty {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 1rem;
  color: var(--gr); font-size: .95rem;
}

.cart-drawer__footer {
  padding: 1.15rem 1.25rem;
  border-top: 1px solid var(--border);
  background: #fafbfc;
  display: flex; flex-direction: column; gap: .55rem;
}
.cart-drawer__subtotal {
  display: flex; justify-content: space-between; align-items: center;
  font-size: .92rem; color: var(--gr); font-weight: 600;
  padding-bottom: .5rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: .15rem;
}
.cart-drawer__subtotal strong {
  font-size: 1.2rem; font-weight: 800; color: var(--dk);
  font-family: 'Montserrat', sans-serif;
}
.cart-drawer__btn {
  display: flex; align-items: center; justify-content: center; gap: .5rem;
  padding: .75rem; border-radius: 12px;
  font-weight: 700; font-size: .88rem; text-decoration: none;
  cursor: pointer; border: none;
  transition: all .25s ease;
  font-family: inherit;
}
.cart-drawer__btn--outline {
  background: #fff; color: var(--g);
  border: 2px solid var(--g);
}
.cart-drawer__btn--outline:hover { background: var(--gp); transform: translateY(-1px); }
.cart-drawer__btn--green {
  background: var(--g); color: #fff;
  box-shadow: 0 2px 10px rgba(0,170,40,.2);
}
.cart-drawer__btn--green:hover { background: var(--gd); box-shadow: 0 6px 20px rgba(0,170,40,.35); transform: translateY(-1px); }
.cart-drawer__btn--dark {
  background: var(--dk); color: #fff;
  box-shadow: 0 2px 10px rgba(0,0,0,.1);
}
.cart-drawer__btn--dark:hover { background: #2d2d2d; box-shadow: 0 6px 20px rgba(0,0,0,.25); transform: translateY(-1px); }

.fly-particle {
  position: fixed; z-index: 9999; pointer-events: none;
  width: 14px; height: 14px; border-radius: 50%;
  background: var(--g); opacity: 0;
}

/* ====== RESPONSIVE ====== */
@media (max-width: 900px) {
  .product__container {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .product__gallery { position: static; }
}

@media (max-width: 640px) {
  .product-section { padding: 2rem 0 3rem; }
  .product__container { padding: 0 1.25rem; }
  .product__actions { flex-direction: column; }
  .product__add-btn { padding: .85rem; }
  .product__name { font-size: 1.3rem; }
  .product__price { font-size: 1.6rem; }
  .desc-section { padding: 3rem 0 3.5rem; }
  .desc-section__container { padding: 0 1.25rem; }
  .related { padding: 3rem 0 3.5rem; }
  .related__container { padding: 0 1.25rem; }
  .rp-btn { font-size: .88rem; padding: .8rem 1.6rem; }
  .cta { min-height: 45vh; padding: 3.5rem 0; }
  .cta__container { padding: 0 1.25rem; }
  .cta__title { font-size: clamp(1.6rem, 7vw, 2.2rem); }
  .cta__actions { flex-direction: column; }
  .cta__actions .rp-btn { justify-content: center; }
  .breadcrumbs__container { font-size: .78rem; }
}

/* ====== ANIMATIONS ====== */
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: .5; transform: scale(.85); }
}

[data-anim] {
  opacity: 0; transform: translateY(30px);
  transition: opacity var(--ease), transform var(--ease);
}
[data-anim="fade-left"] { transform: translateX(40px); }
[data-anim="fade-right"] { transform: translateX(-40px); }
[data-anim].is-visible { opacity: 1; transform: none; }
</style>

<style is:global>
/* Cart items (generados dinámicamente por JS) */
.cart-item {
  display: flex; gap: .85rem; align-items: center;
  padding: .7rem .75rem;
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  margin-bottom: .55rem;
  box-shadow: 0 1px 4px rgba(0,0,0,.05);
  transition: box-shadow .2s;
}
.cart-item:hover { box-shadow: 0 3px 12px rgba(0,0,0,.08); }
.cart-item__img {
  width: 82px; height: 82px; border-radius: 10px;
  background: linear-gradient(145deg, #f5f6f5 0%, #eaeceb 100%);
  overflow: hidden; flex-shrink: 0;
  padding: 5px;
}
.cart-item__img img {
  width: 100%; height: 100%; object-fit: cover;
  border-radius: 7px; mix-blend-mode: multiply;
}
.cart-item__info { flex: 1; min-width: 0; }
.cart-item__name {
  font-size: .88rem; font-weight: 700; color: #1a1a1a; margin: 0 0 .2rem;
  line-height: 1.3;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.cart-item__price {
  font-size: .88rem; font-weight: 800; color: #00AA28;
  margin: 0 0 .4rem;
}
.cart-item__bottom {
  display: flex; align-items: center; justify-content: space-between;
}
.cart-item__qty-ctrl {
  display: inline-flex; align-items: center;
  border: 1px solid #e5e7eb; border-radius: 8px;
  overflow: hidden;
}
.cart-item__qty-btn {
  width: 28px; height: 26px;
  background: #f8f9fa; border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: #1a1a1a; font-size: .82rem;
  transition: background .15s, color .15s;
}
.cart-item__qty-btn:hover { background: #e8f9ed; color: #00AA28; }
.cart-item__qty-val {
  width: 30px; height: 26px;
  display: flex; align-items: center; justify-content: center;
  font-size: .78rem; font-weight: 700; color: #1a1a1a;
  border-left: 1px solid #e5e7eb;
  border-right: 1px solid #e5e7eb;
  background: #fff;
}
.cart-item__remove {
  width: 28px; height: 28px; min-width: 28px;
  border-radius: 7px; border: none;
  background: transparent;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: #ef4444;
  transition: background .2s, color .2s;
  flex-shrink: 0;
}
.cart-item__remove:hover { background: #fee2e2; color: #dc2626; }
</style>

<script>
// ===== ANIMATIONS =====
const observer = new IntersectionObserver(
  (entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const delay = parseInt(el.dataset.delay || '0');
        setTimeout(() => el.classList.add('is-visible'), delay);
        observer.unobserve(el);
      }
    });
  },
  { threshold: 0.1 }
);
document.querySelectorAll('[data-anim]').forEach((el) => observer.observe(el));

// ===== GALLERY THUMBS =====
document.querySelectorAll('.product__thumb').forEach(thumb => {
  thumb.addEventListener('click', () => {
    const src = (thumb as HTMLElement).dataset.src!;
    const mainImg = document.getElementById('main-img') as HTMLImageElement;
    mainImg.src = src;
    document.querySelectorAll('.product__thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  });
});

// ===== TIPOS =====
interface CartItem {
  id: string;
  nombre: string;
  precio: number;
  cantidad: number;
  imagen: string;
}

// ===== UTILIDADES =====
function formatARS(n: number): string {
  return '$ ' + n.toLocaleString('es-AR');
}
function saveCart(cart: CartItem[]): void {
  localStorage.setItem('rp-cart', JSON.stringify(cart));
  document.dispatchEvent(new Event('cart-updated'));
}
function loadCart(): CartItem[] {
  try { return JSON.parse(localStorage.getItem('rp-cart') || '[]'); }
  catch { return []; }
}

// ===== CARRITO STATE =====
let cart: CartItem[] = loadCart();

// ===== RENDER CART =====
function renderCart(): void {
  const itemsEl  = document.getElementById('cart-items')!;
  const emptyEl  = document.getElementById('cart-empty')!;
  const footerEl = document.getElementById('cart-footer')!;
  const subtotalEl = document.getElementById('cart-subtotal')!;
  const badge = document.getElementById('cart-badge')!;

  const totalUnits = cart.reduce((s, i) => s + i.cantidad, 0);
  badge.textContent = String(totalUnits);
  badge.classList.toggle('hidden', totalUnits === 0);

  if (cart.length === 0) {
    itemsEl.innerHTML = '';
    emptyEl.style.display = 'flex';
    footerEl.style.display = 'none';
    return;
  }

  emptyEl.style.display = 'none';
  footerEl.style.display = 'flex';

  itemsEl.innerHTML = cart.map(item => {
    const imgFull = item.imagen.replace(/-\d+x\d+(\.\w+)$/, '$1');
    return `
    <div class="cart-item" data-id="${item.id}">
      <div class="cart-item__img">
        <img src="${imgFull}" alt="${item.nombre}" />
      </div>
      <div class="cart-item__info">
        <p class="cart-item__name">${item.nombre}</p>
        <p class="cart-item__price">${formatARS(item.precio * item.cantidad)}</p>
        <div class="cart-item__bottom">
          <div class="cart-item__qty-ctrl">
            <button class="cart-item__qty-btn" data-qty-minus="${item.id}">−</button>
            <span class="cart-item__qty-val">${item.cantidad}</span>
            <button class="cart-item__qty-btn" data-qty-plus="${item.id}">+</button>
          </div>
          <button class="cart-item__remove" data-remove="${item.id}" aria-label="Eliminar">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  `}).join('');

  itemsEl.querySelectorAll('[data-remove]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.remove!;
      cart = cart.filter(i => i.id !== id);
      saveCart(cart); renderCart();
    });
  });

  itemsEl.querySelectorAll('[data-qty-minus]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.qtyMinus!;
      const item = cart.find(i => i.id === id);
      if (item && item.cantidad > 1) { item.cantidad--; saveCart(cart); renderCart(); }
    });
  });

  itemsEl.querySelectorAll('[data-qty-plus]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.qtyPlus!;
      const item = cart.find(i => i.id === id);
      if (item) { item.cantidad++; saveCart(cart); renderCart(); }
    });
  });

  const subtotal = cart.reduce((s, i) => s + i.precio * i.cantidad, 0);
  subtotalEl.textContent = formatARS(subtotal);

  const checkoutTotal = document.getElementById('cart-checkout-total');
  if (checkoutTotal) checkoutTotal.textContent = formatARS(subtotal);

  const headerBadge = document.getElementById('cart-header-badge');
  if (headerBadge) {
    headerBadge.textContent = String(totalUnits);
    headerBadge.classList.toggle('hidden', totalUnits === 0);
  }
}

// ===== OPEN / CLOSE DRAWER =====
function openCart(): void {
  document.getElementById('cart-drawer')!.classList.add('open');
  document.getElementById('cart-overlay')!.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeCart(): void {
  document.getElementById('cart-drawer')!.classList.remove('open');
  document.getElementById('cart-overlay')!.classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('cart-fab')!.addEventListener('click', openCart);
document.getElementById('cart-close')!.addEventListener('click', closeCart);
document.getElementById('cart-overlay')!.addEventListener('click', closeCart);
document.getElementById('cart-continue')!.addEventListener('click', closeCart);

// ===== FLY TO CART =====
function flyToCart(originEl: HTMLElement): void {
  const particle = document.getElementById('fly-particle')!;
  const fab = document.getElementById('cart-fab')!;
  const origin = originEl.getBoundingClientRect();
  const target = fab.getBoundingClientRect();

  const startX = origin.left + origin.width / 2 - 7;
  const startY = origin.top  + origin.height / 2 - 7;
  const endX   = target.left + target.width  / 2 - 7;
  const endY   = target.top  + target.height / 2 - 7;

  particle.style.cssText = `left:${startX}px; top:${startY}px; opacity:1;`;
  void particle.offsetWidth;

  particle.style.transition = `left .6s cubic-bezier(.23,1,.32,1), top .6s cubic-bezier(.23,1,.32,1), opacity .6s ease, transform .6s ease`;
  particle.style.left = endX + 'px';
  particle.style.top  = endY + 'px';
  particle.style.opacity = '0';
  particle.style.transform = 'scale(0)';

  setTimeout(() => { particle.style.cssText = ''; }, 700);
}

// ===== PRODUCT ADD TO CART =====
const actionsWrap = document.querySelector('.product__actions') as HTMLElement;
const qtyInput = document.getElementById('qty-input') as HTMLInputElement;
const addBtn = document.getElementById('add-to-cart') as HTMLButtonElement;
const priceEl = document.getElementById('product-price') as HTMLElement;
const unitPrice = Number(priceEl.dataset.unitPrice);
const multiplo = Number(actionsWrap.dataset.multiplo) || 1;

function updateProductPrice() {
  const qty = Number(qtyInput.value);
  priceEl.textContent = formatARS(unitPrice * qty);
}

document.getElementById('qty-minus')!.addEventListener('click', () => {
  const val = Number(qtyInput.value);
  if (val > multiplo) { qtyInput.value = String(val - multiplo); updateProductPrice(); }
});

document.getElementById('qty-plus')!.addEventListener('click', () => {
  qtyInput.value = String(Number(qtyInput.value) + multiplo);
  updateProductPrice();
});

addBtn.addEventListener('click', () => {
  const id = actionsWrap.dataset.id!;
  const nombre = actionsWrap.dataset.nombre!;
  const precio = Number(actionsWrap.dataset.precio);
  const imagen = actionsWrap.dataset.imagen!;
  const cantidad = Number(qtyInput.value);

  const existing = cart.find(i => i.id === id);
  if (existing) { existing.cantidad += cantidad; }
  else { cart.push({ id, nombre, precio, cantidad, imagen }); }
  saveCart(cart);
  renderCart();
  flyToCart(addBtn);
  setTimeout(() => openCart(), 500);

  addBtn.textContent = '✓ Agregado';
  addBtn.classList.add('added');
  setTimeout(() => {
    addBtn.innerHTML = `<svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg> Agregar al carrito`;
    addBtn.classList.remove('added');
  }, 1800);
});

// ===== INIT =====
renderCart();
</script>
