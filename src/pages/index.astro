---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCategorias } from '../lib/wordpress';

const categoriasLineas = [
  {
    titulo: 'Línea Estándar',
    descripcion: 'Bobinas, camiseta, consorcio, emblocadas y más. Medidas listas para entregar.',
    imagen: '/images/cat-estandar.webp',
    link: '/productos?cat=estandar'
  },
  {
    titulo: 'Línea Impresa',
    descripcion: 'Tu marca impresa con flexografía de alta calidad. Hasta 4 colores.',
    imagen: '/images/cat-impresion.webp',
    link: '/productos?cat=impresion'
  },
  {
    titulo: 'Línea Personalizada',
    descripcion: 'Fabricamos a medida. Definimos material, forma y sistema de envasado.',
    imagen: '/images/cat-personalizada.webp',
    link: '/productos?cat=personalizada'
  },
];

// Categorías dinámicas de WooCommerce
const wcCategorias = await getCategorias();
const categoriasProductos = wcCategorias.filter(c => c.count > 0 && c.slug !== 'sin-categorizar');

const stats = [
  { valor: '+13', label: 'Años de experiencia' },
  { valor: '+300', label: 'Clientes activos' },
  { valor: '100%', label: 'Producción nacional' },
];

const heroSlides = [
  '/images/hero/hero-1.jpg',
  '/images/hero/hero-2.jpg',
  '/images/hero/hero-3.jpg',
  '/images/hero/hero-4.jpg',
];
---

<Layout>
  <Header />

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__orb hero__orb--1"></div>
      <div class="hero__orb hero__orb--2"></div>
    </div>

    <div class="hero__container">
      <div class="hero__content">
        <div class="hero__badge" data-reveal>
          <span class="hero__badge-dot"></span>
          Fábrica de Polietileno en Argentina
        </div>

        <h1 class="hero__title" data-reveal data-delay="1">
          Bolsas y film para
          <span class="hero__title-accent">comercio e industria</span>
        </h1>

        <p class="hero__text" data-reveal data-delay="2">
          Fabricación propia con impresión flexográfica. Producción a medida
          y logística propia desde Reconquista, Santa Fe.
        </p>

        <div class="hero__actions" data-reveal data-delay="3">
          <a href="/productos" class="btn btn--primary">
            Explorar Productos
            <svg class="btn__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a href="/contacto" class="btn btn--ghost">
            Pedir Cotización
          </a>
        </div>
      </div>

      <div class="hero__visual" data-reveal data-delay="2">
        <div class="hero__slider" id="hero-slider">
          {heroSlides.map((src, i) => (
            <img
              src={src}
              alt={`RecoPlas fábrica ${i + 1}`}
              class:list={['hero__slide', { 'hero__slide--active': i === 0 }]}
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          ))}
        </div>
        <div class="hero__slider-dots" id="hero-dots">
          {heroSlides.map((_, i) => (
            <button
              class:list={['hero__dot', { 'hero__dot--active': i === 0 }]}
              data-slide={i}
              aria-label={`Imagen ${i + 1}`}
            ></button>
          ))}
        </div>
        <div class="hero__floating-card">
          <div class="hero__floating-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div>
            <p class="hero__floating-title">Fabricación propia</p>
            <p class="hero__floating-sub">Calidad garantizada</p>
          </div>
        </div>
      </div>
    </div>

    <div class="hero__wave">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- ═══ INTRO / QUIÉNES SOMOS ═══ -->
  <section class="intro">
    <div class="intro__container">
      <div class="intro__video-col" data-reveal>
        <div class="intro__video-wrap">
          <video
            autoplay
            muted
            loop
            playsinline
            poster="/images/sobre%20nosotros/hero%20mejorado_resultado.webp"
          >
            <source src="/images/video-fabrica.mp4" type="video/mp4" />
          </video>
          <div class="intro__video-overlay"></div>
          <div class="intro__video-badge">
            <span class="intro__video-badge-dot"></span>
            Nuestra planta en vivo
          </div>
        </div>
        <!-- Stats inline -->
        <div class="intro__stats">
          {stats.map((s) => (
            <div class="intro__stat">
              <span class="intro__stat-number">{s.valor}</span>
              <span class="intro__stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="intro__text-col" data-reveal data-delay="1">
        <span class="section-tag">Sobre RecoPlas</span>
        <h2 class="section-title">
          Fabricamos soluciones en polietileno para
          <span class="section-title__accent">comercio e industria</span>
        </h2>
        <p class="section-text">
          Desde nuestra planta en <strong>Reconquista, Santa Fe</strong>, producimos bolsas y film
          con tecnología propia de extrusión, impresión flexográfica y confección.
        </p>
        <ul class="intro__features">
          <li>
            <div class="intro__feature-icon">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <strong>Fabricación propia</strong>
              <span>Control y calidad constante</span>
            </div>
          </li>
          <li>
            <div class="intro__feature-icon">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <strong>Producción a medida</strong>
              <span>Estándar y personalizada</span>
            </div>
          </li>
          <li>
            <div class="intro__feature-icon">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <strong>Logística propia</strong>
              <span>Entrega segura a todo el país</span>
            </div>
          </li>
        </ul>
        <a href="/nosotros" class="btn btn--primary" style="margin-top: .5rem;">
          Conocer más
          <svg class="btn__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ LÍNEAS DE PRODUCTOS ═══ -->
  <section class="categories">
    <div class="categories__container">
      <div class="categories__header" data-reveal>
        <span class="section-tag">Nuestros Productos</span>
        <h2 class="section-title section-title--center">
          Líneas de productos para
          <span class="section-title__accent">cada necesidad</span>
        </h2>
        <p class="section-text section-text--center">
          Bolsas y film de polietileno en tres líneas pensadas para comercios, industria y distribuidores.
        </p>
      </div>

      <div class="categories__grid">
        {categoriasLineas.map((cat, i) => (
          <a href={cat.link} class="cat-card" data-reveal data-delay={String(i)}>
            <img src={cat.imagen} alt={cat.titulo} class="cat-card__img" loading="lazy" />
            <div class="cat-card__overlay"></div>
            <div class="cat-card__content">
              <h3 class="cat-card__title">{cat.titulo}</h3>
              <p class="cat-card__desc">{cat.descripcion}</p>
              <span class="cat-card__link">
                Ver productos
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ NUESTROS PRODUCTOS ═══ -->
  <section class="featured">
    <div class="featured__container">
      <div class="featured__top" data-reveal>
        <span class="section-tag">Catálogo</span>
        <h2 class="section-title">Explorá nuestras <span class="section-title__accent">categorías</span></h2>
        <p class="section-text">En RecoPlas fabricamos diferentes tipos de bolsas pensadas para cada uso: comercio, industria, logística y más.</p>
      </div>

      <div class="showcase" data-reveal data-delay="1">
        <!-- Imagen izquierda -->
        <div class="showcase__preview">
          <div class="showcase__img-wrap" id="showcase-img-wrap">
            {categoriasProductos.map((cat, i) => (
              cat.image?.src ? (
                <img
                  src={cat.image.src}
                  alt={cat.name}
                  class:list={['showcase__img', { 'showcase__img--active': i === 0 }]}
                  data-cat-index={i}
                  loading="lazy"
                />
              ) : (
                <div
                  class:list={['showcase__img showcase__img--fallback', { 'showcase__img--active': i === 0 }]}
                  data-cat-index={i}
                ></div>
              )
            ))}
          </div>
          <div class="showcase__img-badge" id="showcase-badge">
            <span class="showcase__img-badge-count" id="showcase-badge-count">{categoriasProductos[0]?.count || 0}</span>
            <span class="showcase__img-badge-label">productos</span>
          </div>
        </div>

        <!-- Lista derecha -->
        <div class="showcase__list">
          {categoriasProductos.map((cat, i) => (
            <a
              href={`/productos?cat=${cat.slug}#catalogo`}
              class:list={['showcase__item', { 'showcase__item--active': i === 0 }]}
              data-cat-index={i}
              data-cat-count={cat.count}
            >
              <span class="showcase__item-index">0{i + 1}</span>
              <div class="showcase__item-text">
                <h3 class="showcase__item-name">{cat.name}</h3>
                <span class="showcase__item-count">{cat.count} {cat.count === 1 ? 'producto' : 'productos'}</span>
              </div>
              <div class="showcase__item-arrow">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </div>
            </a>
          ))}

          <a href="/productos" class="btn btn--primary showcase__btn">
            Ir a la tienda
            <svg class="btn__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CLIENTES ═══ -->
  <section class="clients">
    <div class="clients__container">
      <div class="clients__header" data-reveal>
        <span class="section-tag">Clientes</span>
        <h2 class="section-title section-title--center">Empresas que confían en nosotros</h2>
      </div>
      <div class="clients__track-wrap">
        <div class="clients__track">
          {[1, 2, 3].map(() => (
            <div class="clients__set">
              {[1, 2, 3, 4].map((n) => (
                <div class="clients__logo">
                  <img src={`/images/cliente-${n}.webp`} alt={`Cliente ${n}`} loading="lazy" />
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="cta">
    <div class="cta__bg">
      <img src="/images/hero-empresa.jpg" alt="" loading="lazy" />
      <div class="cta__overlay"></div>
    </div>
    <div class="cta__container" data-reveal>
      <div class="cta__badge">
        <span class="cta__badge-dot"></span>
        Tienda Online
      </div>
      <h2 class="cta__title">
        Explorá nuestro
        <span class="cta__title-accent">catálogo completo</span>
      </h2>
      <p class="cta__text">
        Bolsas, bobinas, film y más. Encontrá el producto que necesitás y hacé tu pedido online.
      </p>
      <div class="cta__actions">
        <a href="/productos" class="btn btn--primary btn--lg">
          Ir a la tienda
          <svg class="btn__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a href="https://wa.me/543482200375" target="_blank" rel="noopener" class="btn btn--white-ghost btn--lg">
          <svg class="btn__icon" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Consultanos
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ═══════════════════════════════════════════
     DESIGN SYSTEM — Variables locales
  ═══════════════════════════════════════════ */
  :root {
    --green: #00AA28;
    --green-dark: #008f22;
    --green-pale: #e8f9ed;
    --dark: #111827;
    --dark-soft: #1e293b;
    --gray: #64748b;
    --gray-light: #f8fafc;
    --border: #e5e7eb;
    --radius: 16px;
    --radius-lg: 24px;
    --ease: .5s cubic-bezier(.23, 1, .32, 1);
    --container: 1280px;
  }

  /* ═══════════════════════════════════════════
     SHARED COMPONENTS
  ═══════════════════════════════════════════ */

  /* Section tag */
  .section-tag {
    display: inline-block;
    font-size: .72rem; font-weight: 800;
    letter-spacing: .15em; text-transform: uppercase;
    color: var(--green); background: var(--green-pale);
    padding: .4rem 1rem; border-radius: 999px;
    margin-bottom: .75rem;
  }

  /* Section title */
  .section-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800; line-height: 1.15;
    color: var(--dark); margin: 0 0 1rem;
  }
  .section-title--center { text-align: center; }
  .section-title__accent { color: var(--green); }

  /* Section text */
  .section-text {
    color: var(--gray); line-height: 1.8; margin: 0 0 1rem; font-size: .95rem;
  }
  .section-text--center { text-align: center; max-width: 600px; margin-left: auto; margin-right: auto; }
  .section-text strong { color: var(--dark); }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; gap: .5rem;
    font-weight: 700; font-size: .9rem; line-height: 1;
    padding: .85rem 2rem; border-radius: 999px;
    text-decoration: none; cursor: pointer;
    border: 2px solid transparent;
    transition: all .3s ease;
  }
  .btn__icon { width: 18px; height: 18px; flex-shrink: 0; }

  .btn--primary {
    background: var(--green); color: #fff; border-color: var(--green);
    box-shadow: 0 4px 15px rgba(0, 170, 40, .25);
  }
  .btn--primary:hover {
    background: var(--green-dark); border-color: var(--green-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 170, 40, .35);
  }

  .btn--outline {
    background: transparent; color: var(--green); border-color: var(--green);
  }
  .btn--outline:hover {
    background: var(--green); color: #fff;
    transform: translateY(-2px);
  }

  .btn--ghost {
    background: rgba(255,255,255,.1); color: #fff;
    border-color: rgba(255,255,255,.25);
    backdrop-filter: blur(8px);
  }
  .btn--ghost:hover {
    background: rgba(255,255,255,.2);
    border-color: rgba(255,255,255,.4);
  }

  .btn--white-ghost {
    background: rgba(255,255,255,.08); color: #fff;
    border-color: rgba(255,255,255,.2);
    backdrop-filter: blur(8px);
  }
  .btn--white-ghost:hover {
    background: rgba(255,255,255,.15);
    border-color: rgba(255,255,255,.35);
  }

  .btn--lg { padding: 1rem 2.5rem; font-size: .95rem; }

  /* ═══════════════════════════════════════════
     REVEAL ANIMATION (unified)
  ═══════════════════════════════════════════ */
  [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity .7s cubic-bezier(.23,1,.32,1), transform .7s cubic-bezier(.23,1,.32,1);
  }
  [data-reveal].revealed {
    opacity: 1; transform: translateY(0);
  }
  [data-delay="1"] { transition-delay: .1s; }
  [data-delay="2"] { transition-delay: .2s; }
  [data-delay="3"] { transition-delay: .3s; }
  [data-delay="4"] { transition-delay: .4s; }

  /* ═══════════════════════════════════════════
     HERO
  ═══════════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex; align-items: center;
    overflow: hidden;
    padding-bottom: 5rem;
  }

  .hero__bg {
    position: absolute; inset: 0;
  }
  .hero__gradient {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-soft) 50%, rgba(0,170,40,.12) 100%);
  }
  .hero__orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); pointer-events: none;
  }
  .hero__orb--1 {
    top: -10%; left: -5%;
    width: 500px; height: 500px;
    background: var(--green);
    opacity: .06;
  }
  .hero__orb--2 {
    bottom: -15%; right: -5%;
    width: 600px; height: 600px;
    background: var(--green);
    opacity: .04;
  }

  .hero__container {
    position: relative; z-index: 2;
    max-width: var(--container); margin: 0 auto;
    padding: 0 2rem;
    display: grid; grid-template-columns: 1.4fr 1fr;
    gap: 3rem; align-items: center;
    width: 100%;
  }

  .hero__badge {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(255,255,255,.08);
    backdrop-filter: blur(10px);
    padding: .5rem 1.2rem; border-radius: 999px;
    margin-bottom: 1.5rem;
    color: rgba(255,255,255,.85); font-size: .82rem; font-weight: 600;
    border: 1px solid rgba(255,255,255,.08);
  }
  .hero__badge-dot {
    width: 8px; height: 8px;
    background: var(--green); border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .hero__title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 800; line-height: 1.1;
    color: #fff; margin: 0 0 1.5rem;
  }
  .hero__title-accent {
    display: block;
    background: linear-gradient(135deg, var(--green) 0%, #00dd35 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__text {
    font-size: 1.05rem; line-height: 1.8;
    color: rgba(255,255,255,.65);
    margin: 0 0 2rem;
    max-width: 520px;
  }

  .hero__actions { display: flex; flex-wrap: wrap; gap: 1rem; }

  /* Slider */
  .hero__visual {
    display: none; position: relative;
  }

  .hero__slider {
    position: relative;
    width: 100%; height: 400px;
    border-radius: var(--radius-lg); overflow: hidden;
    background: rgba(255,255,255,.05);
    box-shadow: 0 30px 60px rgba(0,0,0,.3);
    border: 1px solid rgba(255,255,255,.06);
  }
  .hero__slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: contain;
    opacity: 0;
    transition: opacity .8s ease-in-out;
    padding: 1rem;
  }
  .hero__slide--active { opacity: 1; }

  .hero__slider-dots {
    display: flex; justify-content: center;
    gap: .5rem; margin-top: 1rem;
  }
  .hero__dot {
    width: 10px; height: 10px; border-radius: 50%;
    border: 2px solid rgba(255,255,255,.3);
    background: transparent;
    cursor: pointer; padding: 0;
    transition: all .3s ease;
  }
  .hero__dot--active {
    background: var(--green); border-color: var(--green);
