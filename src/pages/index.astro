<script>
  // Unified reveal animation
  const revealObs = new IntersectionObserver(
    (entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          revealObs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach(el => revealObs.observe(el));

  // Hero slider
  (() => {
    const slides = document.querySelectorAll('.hero__slide');
    const dots = document.querySelectorAll('.hero__dot');
    if (slides.length === 0) return;

    let current = 0;
    let interval: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      slides[current].classList.remove('hero__slide--active');
      dots[current].classList.remove('hero__dot--active');
      current = index;
      slides[current].classList.add('hero__slide--active');
      dots[current].classList.add('hero__dot--active');
    }

    function next() {
      goTo((current + 1) % slides.length);
    }

    function startAuto() {
      interval = setInterval(next, 4000);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        clearInterval(interval);
        goTo(Number((dot as HTMLElement).dataset.slide));
        startAuto();
      });
    });

    startAuto();
  })();

  // Showcase: interactive category preview
  (() => {
    const items = document.querySelectorAll<HTMLElement>('.showcase__item');
    const images = document.querySelectorAll<HTMLElement>('.showcase__img');
    const badgeCount = document.getElementById('showcase-badge-count');
    if (items.length === 0 || images.length === 0) return;

    let activeIndex = 0;

    function activate(index: number) {
      if (index === activeIndex) return;

      items[activeIndex].classList.remove('showcase__item--active');
      items[index].classList.add('showcase__item--active');

      images[activeIndex].classList.remove('showcase__img--active');
      images[index].classList.add('showcase__img--active');

      if (badgeCount) {
        const count = items[index].dataset.catCount || '0';
        badgeCount.textContent = count;
      }

      activeIndex = index;
    }

    items.forEach((item) => {
      item.addEventListener('mouseenter', () => {
        const idx = Number(item.dataset.catIndex);
        activate(idx);
      });
    });
  })();
</script>
