---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const productosEstandar = [
  'Bobinas de Arranque',
  'Bolsas Camiseta',
  'Bolsas Emblocadas',
  'Residuo, Consorcio y Super Consorcio',
  'Bolsas Riñón',
  'Láminas',
  'Bolsas Impresas Estándar',
  'Film Stretch',
];

const sectores = [
  { nombre: 'Yerbateras', icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z' },
  { nombre: 'Frigoríficos', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4' },
  { nombre: 'Aserraderos', icon: 'M4 6h16M4 10h16M4 14h16M4 18h16' },
  { nombre: 'Fábricas de hielo y helado', icon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707' },
  { nombre: 'Fábricas de pastas', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  { nombre: 'Panaderías y pastelerías', icon: 'M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0A1.75 1.75 0 003 15.546' },
];

const proceso = [
  { numero: '01', titulo: 'Contacto', descripcion: 'Definimos junto a vos la medida, material, forma, diseño y cantidad de colores.' },
  { numero: '02', titulo: 'Diseño', descripcion: 'Nuestro departamento de diseño elabora las muestras para tu aprobación.' },
  { numero: '03', titulo: 'Aprobación', descripcion: 'Revisás y aprobás el diseño final antes de pasar a producción.' },
  { numero: '04', titulo: 'Producción', descripcion: 'Impresión y confección del producto final con los más altos estándares.' },
];
---

<Layout title="Servicios | Reco-Plas" description="Línea estándar y personalizada de bolsas de polietileno. Fabricación propia con materias primas de alta calidad. Envíos a todo el país.">
  <Header />

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-secondary via-secondary to-primary/20"></div>
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-20 left-10 w-72 h-72 bg-primary rounded-full blur-3xl opacity-[.06]"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-primary rounded-full blur-3xl opacity-[.04]"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="text-white">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full mb-6 animate-on-load animate-fade-in-up">
            <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
            <span class="text-sm font-medium">Nuestros Servicios</span>
          </div>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 animate-on-load animate-fade-in-up delay-100">
            Dos líneas,
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-light">
              una calidad
            </span>
          </h1>

          <p class="text-lg text-white/80 mb-8 max-w-xl animate-on-load animate-fade-in-up delay-200">
            Fabricamos con materias primas de alta calidad logrando productos
            con la elasticidad y consistencia que tu negocio necesita.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 animate-on-load animate-fade-in-up delay-300">
            <a
              href="#linea-estandar"
              class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-8 py-4 rounded-full font-semibold transition-all duration-300 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5"
            >
              Conocer más
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
              </svg>
            </a>
            <a
              href="/contacto"
              class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white text-white px-8 py-4 rounded-full font-semibold transition-all duration-300 hover:bg-white/10"
            >
              Pedir Cotización
            </a>
          </div>
        </div>

        <div class="hidden lg:flex justify-center animate-on-load animate-slide-right delay-400">
          <div class="relative">
            <div class="w-96 h-96 rounded-3xl overflow-hidden shadow-2xl">
              <img src="/images/sobre%20nosotros/hero%20mejorado_resultado.webp" alt="Servicios RecoPlas" class="w-full h-full object-cover" />
            </div>
            <div class="absolute -bottom-4 -left-4 bg-white rounded-xl p-4 shadow-xl">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-secondary text-sm">Fabricación propia</p>
                  <p class="text-xs text-gray">Calidad garantizada</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- LÍNEA ESTÁNDAR -->
  <section class="py-24" id="linea-estandar">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="scroll-reveal">
          <span class="text-primary font-semibold uppercase tracking-wider text-sm">Línea Estándar</span>
          <h2 class="text-3xl md:text-4xl font-bold text-secondary mt-3 mb-5">
            Productos listos para entregar
          </h2>
          <p class="text-gray leading-relaxed mb-8">
            Nuestra línea estándar está pensada para distribuidores pequeños y grandes que buscan
            posicionarse en el mercado con productos de calidad que marcan la diferencia,
            proyectando desarrollo y crecimiento económico.
          </p>

          <div class="grid grid-cols-2 gap-3">
            {productosEstandar.map((producto) => (
              <div class="flex items-center gap-2.5">
                <div class="w-5 h-5 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-secondary text-sm font-medium">{producto}</span>
              </div>
            ))}
          </div>

          <a
            href="/productos"
            class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white px-7 py-3.5 rounded-full font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-0.5 mt-8"
          >
            Ver Catálogo Completo
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        <div class="scroll-reveal">
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img
              src="/images/sobre%20nosotros/confeccion%201%20mejorado_resultado.webp"
              alt="Línea Estándar RecoPlas"
              class="w-full h-[400px] object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LÍNEA PERSONALIZADA -->
  <section class="py-24 bg-gray-light">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="lg:order-2 scroll-reveal">
          <span class="text-primary font-semibold uppercase tracking-wider text-sm">Línea Personalizada</span>
          <h2 class="text-3xl md:text-4xl font-bold text-secondary mt-3 mb-5">
            Empaques a tu medida
          </h2>
          <p class="text-gray leading-relaxed mb-6">
            Desarrollamos empaques personalizados para satisfacer las demandas específicas
            de diversos sectores industriales y comerciales. Láminas y bolsas sueltas
            en alta y baja densidad, impresas o sin impresión, incluyendo material termocontraíble.
          </p>
          <p class="text-gray leading-relaxed mb-8">
            Definimos junto a vos la medida, material, forma, diseño, cantidad de colores
            y sistema de envasado de destino. Elaboramos presupuestos a medida.
          </p>

          <h3 class="text-lg font-bold text-secondary mb-4">Sectores que atendemos</h3>
          <div class="grid grid-cols-2 gap-3 mb-8">
            {sectores.map((sector) => (
              <div class="flex items-center gap-2.5">
                <div class="w-5 h-5 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-secondary text-sm font-medium">{sector.nombre}</span>
              </div>
            ))}
          </div>

          <a
            href="/contacto"
            class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white px-7 py-3.5 rounded-full font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-0.5"
          >
            Solicitar Cotización
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        <div class="lg:order-1 scroll-reveal">
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img
              src="/images/sobre%20nosotros/impresion%201%20%20mejorado_resultado.webp"
              alt="Línea Personalizada RecoPlas"
              class="w-full h-[400px] object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO PERSONALIZADO -->
  <section class="py-24">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-2xl mx-auto mb-16 scroll-reveal">
        <span class="text-primary font-semibold uppercase tracking-wider text-sm">¿Cómo trabajamos?</span>
        <h2 class="text-3xl md:text-4xl font-bold text-secondary mt-3 mb-4">
          Proceso de desarrollo personalizado
        </h2>
        <p class="text-gray">
          Desde tu consulta hasta la entrega, hacemos que todo sea simple.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {proceso.map((paso, i) => (
          <div class="scroll-reveal" style={`transition-delay: ${i * 100}ms`}>
            <div class="bg-white rounded-2xl p-8 h-full border border-gray-100 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
              <span class="text-5xl font-bold text-primary/15 block mb-4">{paso.numero}</span>
              <h3 class="text-xl font-bold text-secondary mb-3">{paso.titulo}</h3>
              <p class="text-gray text-sm leading-relaxed">{paso.descripcion}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative min-h-[400px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/sobre%20nosotros/segundo%20hero%20mejorado_resultado.webp" alt="Planta RecoPlas" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-secondary/95 via-secondary/80 to-secondary/55"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10 py-20">
      <div class="max-w-2xl scroll-reveal">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-5 leading-tight">
          ¿Necesitás un presupuesto?
        </h2>
        <p class="text-white/80 text-lg mb-8 leading-relaxed">
          Contanos qué necesitás y te preparamos una cotización sin compromiso.
          Respondemos en menos de 24 horas.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contacto"
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-8 py-4 rounded-full font-semibold transition-all duration-300 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5"
          >
            Solicitar Cotización
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="https://wa.me/543482200375"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm hover:bg-white/20 border border-white/30 text-white px-8 py-4 rounded-full font-semibold transition-all duration-300"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .scroll-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  .scroll-reveal.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const revealElements = document.querySelectorAll('.scroll-reveal');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  revealElements.forEach((el) => revealObserver.observe(el));
</script>
