---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Checkout | RecoPlas" description="Completa tus datos para finalizar tu pedido." noindex={true}>
  <Header />

  <section class="checkout">
    <div class="checkout__container">

      <div class="checkout__header">
        <a href="/carrito" class="checkout__back">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Volver al carrito
        </a>
        <h1 class="checkout__title">Finalizar pedido</h1>
      </div>

      <!-- Empty state -->
      <div class="checkout__empty" id="checkout-empty" style="display:none;">
        <svg width="56" height="56" fill="none" stroke="#cbd5e1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
        <p>Tu carrito esta vacio. Agrega productos antes de continuar.</p>
        <a href="/productos" class="rp-btn rp-btn--green">Ir a la tienda</a>
      </div>

      <div class="checkout__layout" id="checkout-layout" style="display:none;">

        <!-- Formulario -->
        <div class="checkout__form-col">

          <!-- Paso 1: Datos -->
          <div class="checkout__section">
            <div class="checkout__section-header">
              <span class="checkout__step">1</span>
              <h2 class="checkout__section-title">Datos de contacto</h2>
            </div>
            <form id="checkout-form" class="checkout__form">
              <div class="checkout__field-row">
                <div class="checkout__field">
                  <label for="nombre">Nombre *</label>
                  <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
                </div>
                <div class="checkout__field">
                  <label for="apellido">Apellido *</label>
                  <input type="text" id="apellido" name="apellido" required placeholder="Tu apellido" />
                </div>
              </div>
              <div class="checkout__field-row">
                <div class="checkout__field">
                  <label for="email">Email *</label>
                  <input type="email" id="email" name="email" required placeholder="tu@email.com" />
                </div>
                <div class="checkout__field">
                  <label for="telefono">Telefono *</label>
                  <input type="tel" id="telefono" name="telefono" required placeholder="Ej: 3482 123456" />
                </div>
              </div>
              <div class="checkout__field">
                <label for="empresa">Empresa / Razon social</label>
                <input type="text" id="empresa" name="empresa" placeholder="Opcional" />
              </div>
              <div class="checkout__field">
                <label for="cuit">CUIT</label>
                <input type="text" id="cuit" name="cuit" placeholder="Opcional" />
              </div>
            </form>
          </div>

          <!-- Paso 2: Pago -->
          <div class="checkout__section">
            <div class="checkout__section-header">
              <span class="checkout__step">2</span>
              <h2 class="checkout__section-title">Metodo de pago</h2>
            </div>
            <div class="checkout__payment-info">
              <div class="checkout__payment-icon">
                <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
              </div>
              <div>
                <strong>Transferencia bancaria</strong>
                <span>Al confirmar tu pedido te mostramos los datos para transferir. Una vez realizada la transferencia, envias el comprobante por WhatsApp.</span>
              </div>
            </div>
          </div>

          <!-- Nota envio y facturacion -->
          <div class="checkout__info-note">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div>
              <strong>Envio y facturacion</strong>
              <span>El costo de envio y la facturacion se coordinan por WhatsApp una vez confirmado el pago.</span>
            </div>
          </div>

          <!-- Notas opcionales -->
          <div class="checkout__section">
            <div class="checkout__field">
              <label for="notas">Notas del pedido (opcional)</label>
              <textarea id="notas" name="notas" form="checkout-form" rows="2" placeholder="Indicaciones especiales, consultas, etc."></textarea>
            </div>
          </div>

          <!-- Error message -->
          <div class="checkout__error" id="checkout-error" style="display:none;">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            <span id="checkout-error-msg"></span>
          </div>

          <button type="submit" form="checkout-form" class="rp-btn rp-btn--green rp-btn--full rp-btn--lg checkout__submit" id="submit-btn">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span id="submit-btn-text">Confirmar pedido</span>
          </button>
        </div>

        <!-- Resumen lateral -->
        <aside class="checkout__summary-col">
          <div class="checkout__summary-card">
            <h3 class="checkout__summary-title">Tu pedido</h3>
            <div class="checkout__summary-items" id="checkout-items">
              <!-- JS -->
            </div>
            <div class="checkout__summary-line checkout__summary-line--total">
              <span>Total productos</span>
              <strong id="checkout-total">$ 0</strong>
            </div>
            <p class="checkout__summary-shipping-note">El costo de envio se coordina por WhatsApp una vez confirmado el pago.</p>
          </div>
        </aside>

      </div>

      <!-- Success -->
      <div class="checkout__success" id="checkout-success" style="display:none;">
        <div class="checkout__success-card">
          <div class="checkout__success-icon">
            <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h2>Pedido <span id="order-number"></span> confirmado</h2>
          <p>Realiza la transferencia con los datos de abajo y envianos el comprobante por WhatsApp.</p>

          <!-- Datos bancarios -->
          <div class="checkout__bank-info">
            <p class="checkout__bank-label">Datos para transferir</p>
            <div class="checkout__bank-rows">
              <div class="checkout__bank-row">
                <span>Banco</span>
                <strong>Macro S.A.</strong>
              </div>
              <div class="checkout__bank-row">
                <span>Titular</span>
                <strong>RECO PLAS S.R.L.</strong>
              </div>
              <div class="checkout__bank-row">
                <span>CUIT</span>
                <strong>30-71685889-4</strong>
              </div>
              <div class="checkout__bank-row checkout__bank-row--highlight">
                <span>CBU</span>
                <strong>2850787530094243665011</strong>
              </div>
              <div class="checkout__bank-row checkout__bank-row--highlight">
                <span>Alias</span>
                <strong>FRIO.PROBADO.PEZ</strong>
              </div>
              <div class="checkout__bank-row checkout__bank-row--total">
                <span>Monto a transferir</span>
                <strong id="bank-total"></strong>
              </div>
            </div>
            <p class="checkout__bank-note">Una vez realizada la transferencia, envianos el comprobante por WhatsApp para confirmar tu pedido.</p>
          </div>

          <!-- Nota envio y facturacion -->
          <div class="checkout__shipping-note">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>El costo de envio y la facturacion se coordinan por WhatsApp una vez confirmado el pago.</span>
          </div>

          <div class="checkout__success-actions">
            <a href="#" target="_blank" rel="noopener" class="rp-btn rp-btn--green rp-btn--full" id="success-wa-btn">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Enviar comprobante por WhatsApp
            </a>
            <a href="/" class="rp-btn rp-btn--outline rp-btn--full">Volver al inicio</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<style>
:root {
  --g: #00AA28; --gd: #008f22; --gp: #e8f9ed;
  --dk: #1a1a1a; --gr: #64748b;
  --border: #e5e7eb;
}

.checkout {
  min-height: 70vh;
  padding: 2rem 0 5rem;
  background: #f8faf9;
}
.checkout__container {
  max-width: 1100px; margin: 0 auto; padding: 0 2rem;
}

.checkout__header { margin-bottom: 2rem; }
.checkout__back {
  display: inline-flex; align-items: center; gap: .4rem;
  color: var(--g); font-weight: 600; font-size: .85rem;
  text-decoration: none; margin-bottom: .75rem;
  transition: gap .3s;
}
.checkout__back:hover { gap: .7rem; }
.checkout__title {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.75rem; font-weight: 800; color: var(--dk); margin: 0;
}

.checkout__empty {
  display: flex; flex-direction: column;
  align-items: center; text-align: center;
  gap: 1rem; padding: 4rem 2rem;
  background: #fff; border-radius: 20px;
  border: 1px solid var(--border);
}
.checkout__empty p { color: var(--gr); font-size: .95rem; margin: 0; }

/* Layout */
.checkout__layout {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 2rem; align-items: start;
}

/* Sections */
.checkout__section {
  background: #fff; border-radius: 20px;
  border: 1px solid var(--border);
  padding: 1.75rem;
  margin-bottom: 1.25rem;
}
.checkout__section-header {
  display: flex; align-items: center; gap: .75rem;
  margin-bottom: 1.5rem;
}
.checkout__step {
  width: 32px; height: 32px; border-radius: 50%;
  background: var(--g); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: .85rem;
  flex-shrink: 0;
}
.checkout__section-title {
  font-size: 1.05rem; font-weight: 800; color: var(--dk); margin: 0;
}

/* Form */
.checkout__form {
  display: flex; flex-direction: column; gap: 1rem;
}
.checkout__field-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
}
.checkout__field {
  display: flex; flex-direction: column; gap: .35rem;
}
.checkout__field label {
  font-size: .8rem; font-weight: 700; color: var(--dk);
}
.checkout__field input,
.checkout__field textarea {
  padding: .7rem 1rem; border-radius: 10px;
  border: 1px solid var(--border);
  font-size: .88rem; font-family: inherit;
  color: var(--dk); background: #fff;
  transition: border-color .2s, box-shadow .2s;
}
.checkout__field input:focus,
.checkout__field textarea:focus {
  outline: none;
  border-color: var(--g);
  box-shadow: 0 0 0 3px rgba(0,170,40,.1);
}
.checkout__field textarea { resize: vertical; }

/* Payment info (single method) */
.checkout__payment-info {
  display: flex; align-items: flex-start; gap: 1rem;
  padding: 1rem 1.25rem; border-radius: 14px;
  border: 2px solid var(--g);
  background: var(--gp);
}
.checkout__payment-icon {
  width: 44px; height: 44px; border-radius: 12px;
  background: #fff; color: var(--g);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.checkout__payment-info strong {
  display: block; font-size: .9rem; color: var(--dk); margin-bottom: .25rem;
}
.checkout__payment-info span {
  font-size: .78rem; color: var(--gr); line-height: 1.5;
}

/* Error */
.checkout__error {
  display: flex; align-items: center; gap: .6rem;
  padding: .85rem 1.15rem; border-radius: 12px;
  background: #fef2f2; border: 1px solid #fecaca;
  color: #dc2626; font-size: .85rem; font-weight: 500;
  margin-bottom: .75rem;
}

/* Submit */
.checkout__submit { margin-top: .5rem; }
.checkout__submit:disabled {
  opacity: .6; cursor: not-allowed; transform: none !important;
}

/* Buttons */
.rp-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: .5rem;
  font-weight: 700; font-size: .9rem;
  padding: .85rem 2rem; border-radius: 999px;
  text-decoration: none; cursor: pointer;
  border: none; transition: all .3s ease;
  font-family: inherit;
}
.rp-btn--green {
  background: var(--g); color: #fff;
  box-shadow: 0 4px 15px rgba(0,170,40,.25);
}
.rp-btn--green:hover { background: var(--gd); transform: translateY(-2px); }
.rp-btn--outline {
  background: #fff; color: var(--g);
  border: 2px solid var(--g);
}
.rp-btn--outline:hover { background: var(--gp); }
.rp-btn--full { width: 100%; }
.rp-btn--lg { padding: 1rem 2.5rem; font-size: .95rem; }

/* Summary */
.checkout__summary-card {
  background: #fff; border-radius: 20px;
  border: 1px solid var(--border);
  padding: 1.5rem; position: sticky; top: 100px;
}
.checkout__summary-title {
  font-size: 1.05rem; font-weight: 800; color: var(--dk);
  margin: 0 0 1rem;
}
.checkout__summary-items {
  display: flex; flex-direction: column; gap: .65rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 1rem;
  max-height: 350px; overflow-y: auto;
}

.checkout__summary-line--total {
  padding-top: .5rem;
}
.checkout__summary-line--total span { font-weight: 600; }
.checkout__summary-line--total strong {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.35rem; font-weight: 900; color: var(--dk);
}

/* Success */
.checkout__success {
  display: flex; justify-content: center;
  padding: 3rem 0;
}
.checkout__success-card {
  background: #fff; border-radius: 24px;
  border: 1px solid var(--border);
  padding: 3rem; text-align: center;
  max-width: 540px; width: 100%;
}
.checkout__success-icon {
  width: 80px; height: 80px; border-radius: 50%;
  background: var(--gp); color: var(--g);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 1.5rem;
}
.checkout__success-card h2 {
  font-size: 1.5rem; font-weight: 800; color: var(--dk); margin: 0 0 .75rem;
}
.checkout__success-card > p {
  color: var(--gr); font-size: .95rem; line-height: 1.7; margin: 0 0 1.5rem;
}
.checkout__success-actions {
  display: flex; flex-direction: column; gap: .75rem;
}

/* Bank info */
.checkout__bank-info {
  margin: 0 0 2rem;
  background: var(--gp);
  border: 1px solid rgba(0,170,40,.2);
  border-radius: 14px;
  padding: 1.25rem;
  text-align: left;
}
.checkout__bank-label {
  font-size: .8rem; font-weight: 700; color: var(--g);
  text-transform: uppercase; letter-spacing: .05em;
  margin: 0 0 .85rem;
}
.checkout__bank-rows {
  display: flex; flex-direction: column; gap: .5rem;
}
.checkout__bank-row {
  display: flex; justify-content: space-between; align-items: center;
  font-size: .85rem; padding: .4rem 0;
  border-bottom: 1px solid rgba(0,170,40,.12);
}
.checkout__bank-row:last-child { border-bottom: none; }
.checkout__bank-row span { color: var(--gr); }
.checkout__bank-row strong { color: var(--dk); font-weight: 700; }
.checkout__bank-row--highlight strong {
  font-family: 'Montserrat', monospace;
  font-size: .9rem; letter-spacing: .03em;
}
.checkout__bank-row--total {
  margin-top: .25rem; padding-top: .65rem;
  border-top: 2px solid rgba(0,170,40,.2) !important;
  border-bottom: none !important;
}
.checkout__bank-row--total span { font-weight: 600; color: var(--dk); }
.checkout__bank-row--total strong {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.1rem; font-weight: 900; color: var(--g);
}
.checkout__bank-note {
  font-size: .78rem; color: var(--gr); margin: .85rem 0 0;
  line-height: 1.5;
}

/* Info note (envio + facturacion) */
.checkout__info-note {
  display: flex; align-items: flex-start; gap: .75rem;
  padding: 1rem 1.25rem; border-radius: 14px;
  background: #f0f9ff; border: 1px solid #bae6fd;
  margin-bottom: 1.25rem;
}
.checkout__info-note svg { flex-shrink: 0; color: #0284c7; margin-top: 2px; }
.checkout__info-note strong {
  display: block; font-size: .85rem; color: #0369a1; margin-bottom: .2rem;
}
.checkout__info-note span {
  font-size: .8rem; color: #0369a1; line-height: 1.5; opacity: .85;
}

/* Shipping note (success) */
.checkout__shipping-note {
  display: flex; align-items: flex-start; gap: .6rem;
  padding: .85rem 1.15rem; border-radius: 12px;
  background: #f0f9ff; border: 1px solid #bae6fd;
  color: #0369a1; font-size: .82rem; font-weight: 500;
  line-height: 1.5; margin-bottom: 1.5rem;
}
.checkout__shipping-note svg { flex-shrink: 0; margin-top: 1px; }

.checkout__summary-shipping-note {
  font-size: .75rem; color: var(--gr); line-height: 1.5;
  margin-top: .75rem; padding-top: .75rem;
  border-top: 1px dashed var(--border);
}

@media (max-width: 900px) {
  .checkout__layout { grid-template-columns: 1fr; }
  .checkout__summary-card { position: static; }
}
@media (max-width: 580px) {
  .checkout { padding: 1.5rem 0 3rem; }
  .checkout__container { padding: 0 1.25rem; }
  .checkout__title { font-size: 1.5rem; }
  .checkout__field-row { grid-template-columns: 1fr; }
  .checkout__section { padding: 1.25rem; }
  .checkout__field label { font-size: .85rem; }
  .checkout__field input, .checkout__field textarea { font-size: .95rem; }
  .checkout__success-card { padding: 2rem 1.5rem; }
  .checkout__bank-row { flex-direction: column; align-items: flex-start; gap: .15rem; }
}
</style>

<style is:global>
/* Checkout summary items (generated by JS) */
.checkout__summary-item {
  display: flex; gap: .75rem; align-items: center;
}
.checkout__summary-item-img {
  width: 52px; height: 52px; border-radius: 8px;
  background: #f5f6f5; overflow: hidden;
  flex-shrink: 0; padding: 3px;
}
.checkout__summary-item-img img {
  width: 100%; height: 100%; object-fit: contain;
  border-radius: 6px;
}
.checkout__summary-item-info { flex: 1; min-width: 0; }
.checkout__summary-item-name {
  font-size: .82rem; font-weight: 600; color: #1a1a1a;
  margin: 0; line-height: 1.3;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.checkout__summary-item-meta {
  font-size: .75rem; color: #64748b; margin: .15rem 0 0;
}
.checkout__summary-item-price {
  font-weight: 800; font-size: .88rem; color: #1a1a1a;
  white-space: nowrap;
}
.checkout__summary-line {
  display: flex; justify-content: space-between;
  font-size: .88rem; color: #64748b;
}
</style>

<script>
interface CartItem {
  id: number;
  nombre: string;
  precio: number;
  cantidad: number;
  imagen: string;
}

const WA_NUMBER = '543482312021';

function formatARS(n: number): string {
  return '$ ' + n.toLocaleString('es-AR');
}
function loadCart(): CartItem[] {
  try { return JSON.parse(localStorage.getItem('rp-cart') || '[]'); }
  catch { return []; }
}

function renderCheckout(): void {
  const cart = loadCart();
  const emptyEl = document.getElementById('checkout-empty')!;
  const layoutEl = document.getElementById('checkout-layout')!;
  const itemsEl = document.getElementById('checkout-items')!;
  const totalEl = document.getElementById('checkout-total')!;

  if (cart.length === 0) {
    emptyEl.style.display = 'flex';
    layoutEl.style.display = 'none';
    return;
  }

  emptyEl.style.display = 'none';
  layoutEl.style.display = 'grid';

  const subtotal = cart.reduce((s, i) => s + i.precio * i.cantidad, 0);

  itemsEl.innerHTML = cart.map(item => {
    const imgFull = item.imagen.replace(/-\d+x\d+(\.\w+)$/, '$1');
    return `
    <div class="checkout__summary-item">
      <div class="checkout__summary-item-img">
        <img src="${imgFull}" alt="${item.nombre}" />
      </div>
      <div class="checkout__summary-item-info">
        <p class="checkout__summary-item-name">${item.nombre}</p>
        <p class="checkout__summary-item-meta">x${item.cantidad}</p>
      </div>
      <span class="checkout__summary-item-price">${formatARS(item.precio * item.cantidad)}</span>
    </div>`;
  }).join('');

  totalEl.textContent = formatARS(subtotal);
}

function showError(msg: string): void {
  const el = document.getElementById('checkout-error')!;
  document.getElementById('checkout-error-msg')!.textContent = msg;
  el.style.display = 'flex';
  el.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function hideError(): void {
  document.getElementById('checkout-error')!.style.display = 'none';
}

// Form submit — create real order in WooCommerce
document.getElementById('checkout-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  hideError();

  const form = e.target as HTMLFormElement;
  const data = new FormData(form);
  const cart = loadCart();
  const total = cart.reduce((s, i) => s + i.precio * i.cantidad, 0);

  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('submit-btn-text')!;

  // Disable button & show loading
  submitBtn.disabled = true;
  btnText.textContent = 'Procesando pedido...';

  try {
    const response = await fetch('/api/order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        nombre: data.get('nombre'),
        apellido: data.get('apellido'),
        email: data.get('email'),
        telefono: data.get('telefono'),
        empresa: data.get('empresa') || '',
        cuit: data.get('cuit') || '',
        notas: data.get('notas') || '',
        cart: cart.map(item => ({
          id: item.id,
          nombre: item.nombre,
          precio: item.precio,
          cantidad: item.cantidad,
        })),
      }),
    });

    const result = await response.json();

    if (!response.ok) {
      throw new Error(result.error || result.details || 'Error al procesar el pedido');
    }

    // Success — show order confirmation
    const orderNumber = result.order_number;
    const orderTotal = result.total ? formatARS(parseFloat(result.total)) : formatARS(total);

    document.getElementById('order-number')!.textContent = `#${orderNumber}`;
    document.getElementById('bank-total')!.textContent = orderTotal;

    // Build WhatsApp message with order number
    let waMsg = `Hola! Realice el pedido #${orderNumber} en la web.\n\n`;
    cart.forEach(item => {
      waMsg += `- ${item.nombre} x${item.cantidad} = ${formatARS(item.precio * item.cantidad)}\n`;
    });
    waMsg += `\n*Total: ${orderTotal}*`;
    waMsg += `\n*Metodo de pago:* Transferencia bancaria`;
    waMsg += `\n\nNombre: ${data.get('nombre')} ${data.get('apellido')}`;
    waMsg += `\nTel: ${data.get('telefono')}`;
    if (data.get('empresa')) waMsg += `\nEmpresa: ${data.get('empresa')}`;

    const waUrl = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(waMsg)}`;
    (document.getElementById('success-wa-btn') as HTMLAnchorElement).href = waUrl;

    // Show success, hide form
    document.getElementById('checkout-layout')!.style.display = 'none';
    document.querySelector('.checkout__header')!.setAttribute('style', 'display:none');
    document.getElementById('checkout-success')!.style.display = 'flex';

    // Clear cart
    localStorage.setItem('rp-cart', '[]');
    document.dispatchEvent(new Event('cart-updated'));

  } catch (err: any) {
    submitBtn.disabled = false;
    btnText.textContent = 'Confirmar pedido';
    showError(err.message || 'Hubo un error. Por favor intenta de nuevo.');
  }
});

renderCheckout();
</script>
